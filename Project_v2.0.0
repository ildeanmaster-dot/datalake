                              If(
                                  !IsBlank(LookUp(col_proj_precedentes, task_idf = ThisItem.task_idf && subtask_idf = 0)),
                                  Notify("⚠️ Remove the precedence linked to this Task before deleting.", NotificationType.Warning, 3500),
                                  If(Confirm("Remove this Task?"),
