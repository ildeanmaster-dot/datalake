                            Properties:
                              FontColor: =RGBA(100, 116, 139, 1)
                              Height: =18
                              Size: =10
                              Text: |-
                                =Text(ThisItem.StartDate, "dd/mm/yyyy") & " → " &
                                Text(ThisItem.EndDate, "dd/mm/yyyy")
                              VerticalAlign: =VerticalAlign.Middle
                              Visible: =varProjStep_ <> 4
                              Width: =220
                              X: =110
                              Y: =34
                        - btn_tree_edit_dates_4:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: =RGBA(203, 213, 225, 1)
                              BorderThickness: =1
                              Color: =RGBA(100, 116, 139, 1)
                              Fill: =If(varEditDatesTaskId = ThisItem.ID, RGBA(232, 243, 251, 1), RGBA(255, 255, 255, 1))
                              Height: =18
                              HoverFill: =RGBA(232, 243, 251, 1)
                              OnSelect: |-
                                =If(varEditDatesTaskId = ThisItem.ID,
                                    Set(varEditDatesTaskId, 0),
                                    Set(varEditDatesTaskId, ThisItem.ID)
                                )
                              RadiusBottomLeft: =4
                              RadiusBottomRight: =4
                              RadiusTopLeft: =4
                              RadiusTopRight: =4
                              Size: =9
                              Text: ="✏️"
                              Visible: =varProjStep_ = 2
                              Width: =28
                              X: =334
                              Y: =34
                        - dp_tree_task_start_5:
                            Control: DatePicker@0.0.46
                            Properties:
                              BorderColor: =RGBA(203, 213, 225, 1)
                              Format: =DateTimeFormat.ShortDate
                              Height: =28
                              OnChange: |-
                                =If(
                                    !IsBlank(Self.SelectedDate),
                                    If(
                                        Self.SelectedDate < reg_project.StartDate || Self.SelectedDate > reg_project.EndDate,
                                        Notify(
                                            "⚠️ Start date out of project scope (" &
                                            Text(reg_project.StartDate, "dd/mm/yyyy") & " – " &
                                            Text(reg_project.EndDate, "dd/mm/yyyy") & ").",
                                            NotificationType.Warning,
                                            3500
                                        )
                                    );
                                    If(
                                        IsError(Patch(Project_Tasks, LookUp(Project_Tasks, ID = ThisItem.ID), {StartDate: Self.SelectedDate})),
                                        Notify("❌ Error updating Start Date.", NotificationType.Error),
                                        ClearCollect(col_proj_ordertask, Filter(Project_Tasks, project_id = reg_project.ID))
                                    )
                                )
                              SelectedDate: =ThisItem.StartDate
                              Visible: =varEditDatesTaskId = ThisItem.ID && varProjStep_ = 2
                              Width: =130
                              X: =110
                              Y: =62
                        - dp_tree_task_end_5:
                            Control: DatePicker@0.0.46
                            Properties:
                              BorderColor: =RGBA(203, 213, 225, 1)
                              Format: =DateTimeFormat.ShortDate
                              Height: =28
                              OnChange: |-
                                =If(
                                    !IsBlank(Self.SelectedDate),
                                    If(
                                        Self.SelectedDate < reg_project.StartDate || Self.SelectedDate > reg_project.EndDate,
                                        Notify(
                                            "⚠️ End date out of project scope (" &
                                            Text(reg_project.StartDate, "dd/mm/yyyy") & " – " &
                                            Text(reg_project.EndDate, "dd/mm/yyyy") & ").",
                                            NotificationType.Warning,
                                            3500
                                        )
                                    );
                                    If(
                                        IsError(Patch(Project_Tasks, LookUp(Project_Tasks, ID = ThisItem.ID), {EndDate: Self.SelectedDate})),
                                        Notify("❌ Error updating End Date.", NotificationType.Error),
                                        ClearCollect(col_proj_ordertask, Filter(Project_Tasks, project_id = reg_project.ID))
                                    )
                                )
                              SelectedDate: =ThisItem.EndDate
                              Visible: =varEditDatesTaskId = ThisItem.ID && varProjStep_ = 2
                              Width: =130
                              X: =248
                              Y: =62
