            - btn_tog_milestone_2:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =If(varTogMilestone, RGBA(0, 103, 176, 1), RGBA(203, 213, 225, 1))
                  Color: =If(varTogMilestone, RGBA(255, 255, 255, 1), RGBA(148, 163, 184, 1))
                  Fill: =If(varTogMilestone, RGBA(0, 103, 176, 1), RGBA(241, 245, 249, 1))
                  FontWeight: =FontWeight.Bold
                  Height: =24
                  HoverFill: =If(varTogMilestone, RGBA(0, 74, 128, 1), RGBA(226, 232, 240, 1))
                  OnSelect: =Set(varTogMilestone, !varTogMilestone)
                  RadiusBottomLeft: =12
                  RadiusBottomRight: =12
                  RadiusTopLeft: =12
                  RadiusTopRight: =12
                  Size: =10
                  Text: =If(varTogMilestone, "ON", "OFF")
                  Visible: =varProjStep_ = 2
                  Width: =50
                  X: =330
                  Y: =466
            - lbl_s2_visible_5:
                Control: Text@0.0.51
                Properties:
                  FontColor: =RGBA(51, 65, 85, 1)
                  Height: =20
                  Size: =12
                  Text: |-
                    ="👁  Visible to Customer"
                  VerticalAlign: =VerticalAlign.Middle
                  Visible: =varProjStep_ = 2
                  Weight: ='TextCanvas.Weight'.Semibold
                  Width: =200
                  X: =20
                  Y: =504
            - btn_tog_visible_2:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =If(varTogVisible, RGBA(26, 122, 74, 1), RGBA(203, 213, 225, 1))
                  Color: =If(varTogVisible, RGBA(255, 255, 255, 1), RGBA(148, 163, 184, 1))
                  Fill: =If(varTogVisible, RGBA(26, 122, 74, 1), RGBA(241, 245, 249, 1))
                  FontWeight: =FontWeight.Bold
                  Height: =24
                  HoverFill: =If(varTogVisible, RGBA(20, 95, 57, 1), RGBA(226, 232, 240, 1))
                  OnSelect: =Set(varTogVisible, !varTogVisible)
                  RadiusBottomLeft: =12
                  RadiusBottomRight: =12
                  RadiusTopLeft: =12
                  RadiusTopRight: =12
                  Size: =10
                  Text: =If(varTogVisible, "ON", "OFF")
                  Visible: =varProjStep_ = 2
                  Width: =50
                  X: =330
                  Y: =500
            - btn_s2_add_task_5:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =ColorFade(Self.Fill, -15%)
                  Color: =RGBA(255, 255, 255, 1)
                  DisabledBorderColor: =RGBA(214, 221, 224, 1)
                  DisabledFill: =RGBA(214, 221, 224, 1)
                  DisplayMode: |-
                    =If(
                        IsBlank(cbb_s2_functional_area_5.Selected) ||
                        IsBlank(cbb_s2_task_5.Selected) ||
                        IsBlank(dp_s2_start_date_5.SelectedDate) ||
                        IsBlank(dp_s2_end_date_5.SelectedDate),
                        DisplayMode.Disabled,
                        DisplayMode.Edit
                    )
                  Fill: =If(IsBlank(varEditTaskNode), RGBA(26, 122, 74, 1), RGBA(0, 103, 176, 1))
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =36
                  HoverFill: =If(IsBlank(varEditTaskNode), RGBA(20, 95, 57, 1), RGBA(0, 74, 128, 1))
                  OnSelect: |-
                    =If(IsBlank(varEditTaskNode),
                        With(
                            {vNextOrder: Coalesce(
                                First(SortByColumns(
                                    Filter(Project_Tasks, project_id = reg_project.ID),
                                    "OrdemTask", SortOrder.Descending
                                )).OrdemTask + 1,
                                1)},
                            With(
                                {rTask: IfError(
                                    Patch(Project_Tasks, Defaults(Project_Tasks), {
                                        project_name: reg_project.Name,
                                        functional_area: cbb_s2_functional_area_5.Selected.NameArea,
                                        functional_area_id: cbb_s2_functional_area_5.Selected.ID,
                                        project_id: reg_project.ID,
                                        TaskName: cbb_s2_task_5.Selected.Name,
                                        task_idf: cbb_s2_task_5.Selected.ID,
                                        OrdemTask: vNextOrder,
                                        StartDate: dp_s2_start_date_5.SelectedDate,
                                        EndDate: dp_s2_end_date_5.SelectedDate,
                                        IsMilestone: varTogMilestone,
                                        IsVisible: varTogVisible,
                                        Status: { Value: "Active" }
                                    }),
                                    Blank()
                                )},
                                If(IsBlank(rTask),
                                    Notify("❌ Error creating Task.", NotificationType.Error),
                                    Notify("✅ Task added successfully!", NotificationType.Success, 2500);
                                    ClearCollect(col_proj_ordertask,
                                        Filter(Project_Tasks, project_id = reg_project.ID)
                                    );
                                    Reset(cbb_s2_functional_area_5);
                                    Reset(cbb_s2_task_5);
                                    Reset(dp_s2_start_date_5);
                                    Reset(dp_s2_end_date_5);
                                    Set(varTogMilestone, false);
                                    Set(varTogVisible, true);
                                    Set(varV4TaskEndDate, Blank())
                                )
                            )
                        ),
                        With(
                            {rEdit: IfError(
                                Patch(Project_Tasks, LookUp(Project_Tasks, ID = varEditTaskNode.ID), {
                                    StartDate: dp_s2_start_date_5.SelectedDate,
                                    EndDate: dp_s2_end_date_5.SelectedDate,
                                    IsMilestone: varTogMilestone,
                                    IsVisible: varTogVisible
                                }),
                                Blank()
                            )},
                            If(IsBlank(rEdit),
                                Notify("❌ Error updating Task.", NotificationType.Error),
                                Notify("✅ Task updated successfully!", NotificationType.Success, 2500);
                                ClearCollect(col_proj_ordertask,
                                    Filter(Project_Tasks, project_id = reg_project.ID)
                                );
                                Set(varEditTaskNode, Blank());
                                Reset(cbb_s2_functional_area_5);
                                Reset(cbb_s2_task_5);
                                Reset(dp_s2_start_date_5);
                                Reset(dp_s2_end_date_5);
                                Set(varTogMilestone, false);
                                Set(varTogVisible, true);
                                Set(varV4TaskEndDate, Blank())
                            )
                        )
                    )
                  PressedFill: =If(IsBlank(varEditTaskNode), RGBA(20, 95, 57, 0.8), RGBA(0, 74, 128, 0.8))
                  RadiusBottomLeft: =7
                  RadiusBottomRight: =7
                  RadiusTopLeft: =7
                  RadiusTopRight: =7
                  Size: =12
                  Text: |-
                    =If(IsBlank(varEditTaskNode), "＋  Add Task", "💾  Save Task")
                  Visible: =varProjStep_ = 2
                  Width: =384
                  X: =20
                  Y: =540
            - btn_s2_cancel_edit_2:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =RGBA(226, 232, 240, 1)
