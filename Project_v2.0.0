                              RadiusBottomRight: =4
                              RadiusTopLeft: =4
                              RadiusTopRight: =4
                              Size: =11
                              Text: ="▼"
                              Visible: =varProjStep_ = 2
                              Width: =28
                              X: =430
                              Y: =56
