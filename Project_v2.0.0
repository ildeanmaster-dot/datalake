                    ="SUBTASKS ADDED" &
                    If(varSelectedTaskNode.ID > 0,
                        " — " & varSelectedTaskNode.TaskName,
                        "")
                  Visible: =varProjStep_ = 3 && CountRows(colSubTasksNoProject) > 0
                  Weight: ='TextCanvas.Weight'.Bold
                  Width: =615
                  X: =435
                  Y: =178
            - gal_s3_subtasks_list_6:
                Control: Gallery@2.15.0
                Variant: Vertical
                Properties:
                  BorderColor: =RGBA(226, 232, 240, 1)
                  BorderThickness: =1
                  Height: =390
                  Items: |-
                    =If(varSelectedTaskNode.ID > 0,
                        Filter(colSubTasksNoProject, task_idf = varSelectedTaskNode.task_idf),
                        colSubTasksNoProject
                    )
                  LoadingSpinner: =LoadingSpinner.None
                  TemplatePadding: =2
                  TemplateSize: =60
                  Visible: =varProjStep_ = 3 && CountRows(colSubTasksNoProject) > 0
                  Width: =615
                  X: =435
                  Y: =196
                Children:
                  - rect_s3_sub_row_6:
                      Control: Rectangle@2.3.0
                      Properties:
                        BorderColor: =RGBA(241, 245, 249, 1)
                        BorderThickness: =1
                        Fill: =If(Mod(ThisItem.OrdemSubTask, 2) = 0, RGBA(248, 250, 252, 1), RGBA(255, 255, 255, 1))
                        Height: =60
                        Width: =611
                  - lbl_s3_sub_task_ref_6:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(148, 163, 184, 1)
                        Height: =24
