                                          ClearCollect(col_proj_ordertask,
                                              Filter(Project_Tasks, project_id = reg_project.ID));
                                          If(varSelectedTaskNode.ID = ThisItem.ID,
                                              Set(varSelectedTaskNode, Blank()));
                                          Notify("✅ Task removed.", NotificationType.Success, 2000)
                                      )
