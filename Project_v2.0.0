                        RadiusBottomRight: =8
                        RadiusTopLeft: =8
                        RadiusTopRight: =8
                        Width: =603
                      Children:
                        - lbl_prec_flat_indent_5:
                            Control: Rectangle@2.3.0
                            Properties:
                              BorderColor: =RGBA(0, 0, 0, 0)
                              Fill: |-
                                =If(ThisItem.tipo = "subtask",
                                    RGBA(0, 103, 176, 0.15),
                                    RGBA(0, 0, 0, 0))
