                  - cnt_tree_card_5:
                      Control: GroupContainer@1.5.0
                      Variant: ManualLayout
                      Properties:
                        BorderColor: |-
                          =If(varProjStep_ = 2 && varEditTaskNode.ID = ThisItem.ID,
                              RGBA(0, 103, 176, 1),
                              If(varProjStep_ >= 3 && varSelectedTaskNode.ID = ThisItem.ID,
                                  RGBA(0, 103, 176, 1),
                                  RGBA(226, 232, 240, 1)))
                        BorderThickness: =1.5
