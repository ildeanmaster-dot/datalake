                  Align: ='TextCanvas.Align'.Start
                  FontColor: =RGBA(148, 163, 184, 1)
                  Height: =18
                  Size: =11
                  Text: |-
                    =Switch(varProjStep_,
                        3, "Already added tasks are hidden from the list",
                        4, "Select a task on the right, then add subtasks",
                        5, "Select a task on the right, then define its dependency"
                    )
                  VerticalAlign: =VerticalAlign.Middle
                  Visible: =varProjStep_ >= 2
                  Width: =400
                  X: =18
                  Y: =196
