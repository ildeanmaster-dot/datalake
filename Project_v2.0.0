                                    RGBA(241, 245, 249, 1),
                                    RGBA(232, 243, 251, 1))
                              FontWeight: =FontWeight.Bold
                              Height: =20
                              RadiusBottomLeft: =4
                              RadiusBottomRight: =4
                              RadiusTopLeft: =4
                              RadiusTopRight: =4
