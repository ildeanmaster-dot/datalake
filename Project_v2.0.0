            - gal_prec_flat_5:
                Control: Gallery@2.15.0
                Variant: Vertical
                Properties:
                  BorderColor: =RGBA(0, 0, 0, 0)
                  Height: =390
                  Items: =Sort(col_proj_precflat, ordemSort, SortOrder.Ascending)
