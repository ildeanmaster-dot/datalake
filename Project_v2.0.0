                  Height: =48
                  Visible: =varProjStep_ >= 2
                  Width: =424
                  Y: =164
            - lbl_panel_title_5:
                Control: Text@0.0.51
                Properties:
                  Align: ='TextCanvas.Align'.Start
                  FontColor: =RGBA(51, 65, 85, 1)
                  Height: =22
                  Size: =13
                  Text: |-
                    =Switch(varProjStep_,
                        3, If(!IsBlank(varEditTaskNode), "✏️  Edit Task", "Add Task"),
                        4, "Add SubTask"
                    )
                  VerticalAlign: =VerticalAlign.Middle
                  Visible: =varProjStep_ >= 2
                  Weight: ='TextCanvas.Weight'.Bold
                  Width: =280
                  X: =18
                  Y: =177
            - lbl_panel_subtitle_5:
                Control: Text@0.0.51
