                              X: =300
                              Y: =56
                        - btn_tree_order_up_7:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: =RGBA(0, 0, 0, 0)
                              BorderThickness: =0
                              Color: =RGBA(100, 116, 139, 1)
                              DisplayMode: =If(ThisItem.OrdemTask <= 1, DisplayMode.Disabled, DisplayMode.Edit)
                              Fill: =RGBA(0, 0, 0, 0)
                              FontWeight: =FontWeight.Bold
                              Height: =22
                              HoverFill: =RGBA(232, 243, 251, 1)
                              OnSelect: |-
                                =With(
                                    {vItemAnterior: LookUp(col_proj_ordertask, OrdemTask = ThisItem.OrdemTask - 1)},
                                    If(!IsBlank(vItemAnterior),
                                        Patch(Project_Tasks, LookUp(Project_Tasks, ID = ThisItem.ID), {OrdemTask: ThisItem.OrdemTask - 1});
                                        Patch(Project_Tasks, LookUp(Project_Tasks, ID = vItemAnterior.ID), {OrdemTask: vItemAnterior.OrdemTask + 1});
                                        ClearCollect(col_proj_ordertask, Filter(Project_Tasks, project_id = reg_project.ID))
                                    )
                                )
                              RadiusBottomLeft: =4
                              RadiusBottomRight: =4
                              RadiusTopLeft: =4
                              RadiusTopRight: =4
                              Size: =11
                              Text: ="▲"
                              Visible: =varProjStep_ = 2
                              Width: =28
                              X: =395
                              Y: =56
                        - btn_tree_order_down_7:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: =RGBA(0, 0, 0, 0)
                              BorderThickness: =0
                              Color: =RGBA(100, 116, 139, 1)
                              DisplayMode: =If(ThisItem.OrdemTask >= Max(col_proj_ordertask, OrdemTask), DisplayMode.Disabled, DisplayMode.Edit)
                              Fill: =RGBA(0, 0, 0, 0)
                              FontWeight: =FontWeight.Bold
                              Height: =22
                              HoverFill: =RGBA(232, 243, 251, 1)
                              OnSelect: |-
