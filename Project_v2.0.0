                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =200
                        X: =126
                  - dp_s3_sub_start_inline_2:
                      Control: DatePicker@0.0.46
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        Format: =DateTimeFormat.ShortDate
                        Height: =26
                        OnChange: |-
                          =If(
                              !IsBlank(Self.SelectedDate),
                              If(
                                  Self.SelectedDate < reg_project.StartDate || Self.SelectedDate > reg_project.EndDate,
                                  Notify(
                                      "⚠️ Start date out of project scope (" &
                                      Text(reg_project.StartDate, "dd/mm/yyyy") & " – " &
                                      Text(reg_project.EndDate, "dd/mm/yyyy") & ").",
                                      NotificationType.Warning,
                                      3500
                                  )
                              );
                              If(
                                  IsError(Patch(Project_SubTask, LookUp(Project_SubTask, ID = ThisItem.ID), {StartDate: Self.SelectedDate})),
                                  Notify("❌ Error updating Start Date.", NotificationType.Error),
                                  ClearCollect(colSubTasksNoProject, Filter(Project_SubTask, project_id = reg_project.ID))
                              )
                          )
                        SelectedDate: =ThisItem.StartDate
                        Width: =140
                        X: =8
                        Y: =30
                  - dp_s3_sub_end_inline_2:
                      Control: DatePicker@0.0.46
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        Format: =DateTimeFormat.ShortDate
                        Height: =26
                        OnChange: |-
                          =If(
                              !IsBlank(Self.SelectedDate),
                              If(
                                  Self.SelectedDate < reg_project.StartDate || Self.SelectedDate > reg_project.EndDate,
                                  Notify(
                                      "⚠️ End date out of project scope (" &
                                      Text(reg_project.StartDate, "dd/mm/yyyy") & " – " &
                                      Text(reg_project.EndDate, "dd/mm/yyyy") & ").",
                                      NotificationType.Warning,
                                      3500
                                  )
                              );
                              If(
                                  IsError(Patch(Project_SubTask, LookUp(Project_SubTask, ID = ThisItem.ID), {EndDate: Self.SelectedDate})),
                                  Notify("❌ Error updating End Date.", NotificationType.Error),
                                  ClearCollect(colSubTasksNoProject, Filter(Project_SubTask, project_id = reg_project.ID))
                              )
                          )
                        SelectedDate: =ThisItem.EndDate
                        Width: =140
                        X: =156
                        Y: =30
                  - btn_s3_sub_order_up_6:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =RGBA(0, 0, 0, 0)
                        BorderThickness: =0
                        Color: =RGBA(100, 116, 139, 1)
                        DisplayMode: =If(ThisItem.OrdemSubTask <= 1, DisplayMode.Disabled, DisplayMode.Edit)
                        Fill: =RGBA(0, 0, 0, 0)
                        FontWeight: =FontWeight.Bold
                        Height: =28
                        HoverFill: =RGBA(232, 243, 251, 1)
                        OnSelect: |-
                          =With(
                              {vSubAnterior: LookUp(colSubTasksNoProject, OrdemSubTask = ThisItem.OrdemSubTask - 1 && task_idf = ThisItem.task_idf)},
                              If(!IsBlank(vSubAnterior),
                                  Patch(Project_SubTask, LookUp(Project_SubTask, ID = ThisItem.ID), {OrdemSubTask: ThisItem.OrdemSubTask - 1});
                                  Patch(Project_SubTask, LookUp(Project_SubTask, ID = vSubAnterior.ID), {OrdemSubTask: vSubAnterior.OrdemSubTask + 1});
                                  ClearCollect(colSubTasksNoProject, Filter(Project_SubTask, project_id = reg_project.ID))
                              )
                          )
                        RadiusBottomLeft: =4
                        RadiusBottomRight: =4
                        RadiusTopLeft: =4
                        RadiusTopRight: =4
                        Size: =10
                        Text: ="▲"
                        Width: =28
                        X: =304
                        Y: =2
                  - btn_s3_sub_order_down_6:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =RGBA(0, 0, 0, 0)
                        BorderThickness: =0
                        Color: =RGBA(100, 116, 139, 1)
                        DisplayMode: =If(ThisItem.OrdemSubTask >= Max(Filter(colSubTasksNoProject, task_idf = ThisItem.task_idf), OrdemSubTask), DisplayMode.Disabled, DisplayMode.Edit)
                        Fill: =RGBA(0, 0, 0, 0)
                        FontWeight: =FontWeight.Bold
                        Height: =28
                        HoverFill: =RGBA(232, 243, 251, 1)
                        OnSelect: |-
                          =With(
                              {vSubSeguinte: LookUp(colSubTasksNoProject, OrdemSubTask = ThisItem.OrdemSubTask + 1 && task_idf = ThisItem.task_idf)},
                              If(!IsBlank(vSubSeguinte),
                                  Patch(Project_SubTask, LookUp(Project_SubTask, ID = ThisItem.ID), {OrdemSubTask: ThisItem.OrdemSubTask + 1});
                                  Patch(Project_SubTask, LookUp(Project_SubTask, ID = vSubSeguinte.ID), {OrdemSubTask: vSubSeguinte.OrdemSubTask - 1});
                                  ClearCollect(colSubTasksNoProject, Filter(Project_SubTask, project_id = reg_project.ID))
                              )
                          )
                        RadiusBottomLeft: =4
                        RadiusBottomRight: =4
                        RadiusTopLeft: =4
                        RadiusTopRight: =4
                        Size: =10
                        Text: ="▼"
                        Width: =28
                        X: =304
                        Y: =30
                  - btn_s3_sub_delete_6:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =RGBA(0, 0, 0, 0)
                        BorderThickness: =0
                        Color: =RGBA(192, 57, 43, 1)
                        Fill: =RGBA(0, 0, 0, 0)
                        FontWeight: =FontWeight.Bold
                        Height: =60
                        HoverFill: =RGBA(253, 237, 236, 1)
                        OnSelect: |-
                          =If(
                              !IsBlank(LookUp(col_proj_precedentes,
                                  subtask_idf = ThisItem.ID &&
                                  task_idf = ThisItem.task_idf)),
                              Notify("⚠️ Remove the precedence linked to this SubTask first.", NotificationType.Warning, 3500),
                              If(Confirm("Remove this SubTask?"),
                                  If(
                                      IsError(Remove(Project_SubTask, ThisItem)),
                                      Notify("❌ Error removing SubTask.", NotificationType.Error),
                                      ClearCollect(colSubTasksNoProject,
                                          Filter(Project_SubTask, project_id = reg_project.ID));
                                      Notify("✅ SubTask removed.", NotificationType.Success, 2000)
                                  )
                              )
                          )
                        PressedFill: =RGBA(253, 237, 236, 0.8)
                        Size: =12
                        Text: |-
                          ="🗑"
                        Width: =36
                        X: =571
            - lbl_s3_subtasks_empty_4:
                Control: Text@0.0.51
