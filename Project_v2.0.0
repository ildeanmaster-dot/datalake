                                    {vItemSeguinte: LookUp(col_proj_ordertask, OrdemTask = ThisItem.OrdemTask + 1)},
                                    If(!IsBlank(vItemSeguinte),
                                        Patch(Project_Tasks, LookUp(Project_Tasks, ID = ThisItem.ID), {OrdemTask: ThisItem.OrdemTask + 1});
                                        Patch(Project_Tasks, LookUp(Project_Tasks, ID = vItemSeguinte.ID), {OrdemTask: vItemSeguinte.OrdemTask - 1});
                                        ClearCollect(col_proj_ordertask, Filter(Project_Tasks, project_id = reg_project.ID))
