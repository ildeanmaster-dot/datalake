                              X: =210
                              Y: =56
                        - btn_tree_add_subtask_2:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: =RGBA(0, 103, 176, 0.3)
                              BorderThickness: =1
                              Color: =RGBA(0, 103, 176, 1)
