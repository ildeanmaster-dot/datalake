                              HoverFill: =RGBA(232, 245, 238, 1)
                              OnSelect: |-
                                =If(
                                    IsError(Patch(Project_Tasks, ThisItem, {IsVisible: !ThisItem.IsVisible})),
                                    Notify("❌ Error updating Visibility.", NotificationType.Error),
                                    ClearCollect(col_proj_ordertask,
                                        Filter(Project_Tasks, project_id = reg_project.ID));
                                    Notify("✅ Visibility updated.", NotificationType.Success, 1500)
                                )
                              RadiusBottomLeft: =4
                              RadiusBottomRight: =4
                              RadiusTopLeft: =4
                              RadiusTopRight: =4
                              Size: =9
