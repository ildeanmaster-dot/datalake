                Control: Text@0.0.51
                Properties:
                  FontColor: |-
                    =If(varSelectedTaskNode.ID = 0,
                        RGBA(192, 57, 43, 1),
                        RGBA(0, 74, 128, 1))
                  Height: =36
                  Size: =12
                  Text: |-
                    =If(varSelectedTaskNode.ID = 0,
                        "←  Select a Task or SubTask on the right to set its precedence",
                        If(varSelectedTaskNode.tipo = "subtask",
                            "✓  SubTask: " & varSelectedTaskNode.SubTaskName & " (" & varSelectedTaskNode.TaskName & ")",
                            "✓  Task: " & varSelectedTaskNode.TaskName))
                  VerticalAlign: =VerticalAlign.Middle
                  Visible: =varProjStep_ = 4
                  Weight: ='TextCanvas.Weight'.Semibold
                  Width: =384
                  X: =20
                  Y: =224
            - lbl_s4_prec_type_5:
                Control: Text@0.0.51
                Properties:
                  FontColor: =RGBA(100, 116, 139, 1)
                  Height: =16
                  Size: =10
                  Text: ="PRECEDING TYPE  *"
                  Visible: =varProjStep_ = 4
                  Weight: ='TextCanvas.Weight'.Bold
                  Width: =384
                  X: =20
                  Y: =276
            - btn_s4_prec_type_task_5:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =If(varSelectedPrecType = "Task", RGBA(0, 103, 176, 1), RGBA(226, 232, 240, 1))
                  BorderThickness: =1.5
                  Color: =If(varSelectedPrecType = "Task", RGBA(0, 103, 176, 1), RGBA(100, 116, 139, 1))
                  DisplayMode: =If(varSelectedTaskNode.ID = 0, DisplayMode.Disabled, DisplayMode.Edit)
                  Fill: =If(varSelectedPrecType = "Task", RGBA(240, 247, 253, 1), RGBA(255, 255, 255, 1))
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =52
                  HoverBorderColor: =RGBA(0, 103, 176, 1)
                  HoverFill: =If(varSelectedPrecType = "Task", RGBA(232, 243, 251, 1), RGBA(248, 250, 252, 1))
                  OnSelect: =Set(varSelectedPrecType, "Task")
                  RadiusBottomLeft: =6
                  RadiusBottomRight: =6
                  RadiusTopLeft: =6
                  RadiusTopRight: =6
                  Size: =12
                  Text: |-
                    ="🔗" & Char(10) & "Task"
                  Visible: =varProjStep_ = 4
                  Width: =120
                  X: =20
                  Y: =296
            - btn_s4_prec_type_subtask_5:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =If(varSelectedPrecType = "Sub-task", RGBA(0, 103, 176, 1), RGBA(226, 232, 240, 1))
                  BorderThickness: =1.5
                  Color: =If(varSelectedPrecType = "Sub-task", RGBA(0, 103, 176, 1), RGBA(100, 116, 139, 1))
                  DisplayMode: =If(varSelectedTaskNode.ID = 0, DisplayMode.Disabled, DisplayMode.Edit)
                  Fill: =If(varSelectedPrecType = "Sub-task", RGBA(240, 247, 253, 1), RGBA(255, 255, 255, 1))
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =52
                  HoverBorderColor: =RGBA(0, 103, 176, 1)
                  HoverFill: =If(varSelectedPrecType = "Sub-task", RGBA(232, 243, 251, 1), RGBA(248, 250, 252, 1))
                  OnSelect: =Set(varSelectedPrecType, "Sub-task")
                  RadiusBottomLeft: =6
                  RadiusBottomRight: =6
                  RadiusTopLeft: =6
                  RadiusTopRight: =6
                  Size: =12
                  Text: ="⛓" & Char(10) & "Sub-task"
                  Visible: =varProjStep_ = 4
                  Width: =120
                  X: =152
                  Y: =296
            - btn_s4_prec_type_manual_5:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =If(varSelectedPrecType = "Manual Date", RGBA(0, 103, 176, 1), RGBA(226, 232, 240, 1))
                  BorderThickness: =1.5
                  Color: =If(varSelectedPrecType = "Manual Date", RGBA(0, 103, 176, 1), RGBA(100, 116, 139, 1))
                  DisplayMode: =If(varSelectedTaskNode.ID = 0, DisplayMode.Disabled, DisplayMode.Edit)
                  Fill: =If(varSelectedPrecType = "Manual Date", RGBA(240, 247, 253, 1), RGBA(255, 255, 255, 1))
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =52
                  HoverBorderColor: =RGBA(0, 103, 176, 1)
                  HoverFill: =If(varSelectedPrecType = "Manual Date", RGBA(232, 243, 251, 1), RGBA(248, 250, 252, 1))
                  OnSelect: =Set(varSelectedPrecType, "Manual Date")
                  RadiusBottomLeft: =6
                  RadiusBottomRight: =6
                  RadiusTopLeft: =6
                  RadiusTopRight: =6
                  Size: =12
                  Text: |-
                    ="📅" & Char(10) & "Manual"
                  Visible: =varProjStep_ = 4
                  Width: =120
                  X: =284
                  Y: =296
            - lbl_s4_prec_task_5:
                Control: Text@0.0.51
                Properties:
                  FontColor: =RGBA(100, 116, 139, 1)
                  Height: =16
                  Size: =10
                  Text: ="PRECEDING TASK"
                  Visible: =varProjStep_ = 4 && varSelectedPrecType = "Task"
                  Weight: ='TextCanvas.Weight'.Bold
                  Width: =384
                  X: =20
                  Y: =362
            - lbl_s4_prec_subtask_5:
                Control: Text@0.0.51
                Properties:
                  FontColor: =RGBA(100, 116, 139, 1)
                  Height: =16
                  Size: =10
                  Text: ="PRECEDING SUBTASK"
                  Visible: =varProjStep_ = 4 && varSelectedPrecType = "Sub-task"
                  Weight: ='TextCanvas.Weight'.Bold
                  Width: =384
                  X: =20
                  Y: =362
            - lbl_s4_manual_start_5:
                Control: Text@0.0.51
                Properties:
                  FontColor: =RGBA(100, 116, 139, 1)
                  Height: =16
                  Size: =10
                  Text: ="START DATE"
                  Visible: =varProjStep_ = 4 && varSelectedPrecType = "Manual Date"
                  Weight: ='TextCanvas.Weight'.Bold
                  Width: =185
                  X: =20
                  Y: =362
            - lbl_s4_manual_end_5:
                Control: Text@0.0.51
                Properties:
                  FontColor: =RGBA(100, 116, 139, 1)
                  Height: =16
                  Size: =10
                  Text: ="END DATE"
                  Visible: =varProjStep_ = 4 && varSelectedPrecType = "Manual Date"
                  Weight: ='TextCanvas.Weight'.Bold
                  Width: =185
                  X: =219
                  Y: =362
            - btn_s4_add_precedence_5:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =ColorFade(Self.Fill, -15%)
                  Color: =RGBA(255, 255, 255, 1)
                  DisabledBorderColor: =RGBA(214, 221, 224, 1)
                  DisabledFill: =RGBA(214, 221, 224, 1)
                  DisplayMode: |-
                    =If(
                        varSelectedTaskNode.ID = 0 || IsBlank(varSelectedPrecType) ||
                        (varSelectedPrecType = "Task" && IsBlank(cbb_s4_prec_task_5.Selected)) ||
                        (varSelectedPrecType = "Sub-task" && IsBlank(cbb_s4_prec_subtask_5.Selected)) ||
                        (varSelectedPrecType = "Manual Date" && (IsBlank(dp_s4_manual_start_5.SelectedDate) || IsBlank(dp_s4_manual_end_5.SelectedDate))) ||
                        !IsBlank(If(varSelectedTaskNode.tipo = "subtask",
                            LookUp(col_proj_precedentes,
                                subtask_idf = varSelectedTaskNode.ID &&
                                task_idf = varSelectedTaskNode.task_idf),
                            LookUp(col_proj_precedentes,
                                task_idf = varSelectedTaskNode.task_idf &&
                                subtask_idf = 0))),
                        DisplayMode.Disabled,
                        DisplayMode.Edit
                    )
                  Fill: =RGBA(26, 122, 74, 1)
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =36
                  HoverFill: =RGBA(20, 95, 57, 1)
                  OnSelect: |-
                    =With(
                        {
                            vIsSubTaskDependente: varSelectedTaskNode.tipo = "subtask",
                            vDependenteTaskIdf: varSelectedTaskNode.task_idf,
                            vDependenteSubTaskIdf: If(varSelectedTaskNode.tipo = "subtask", varSelectedTaskNode.ID, 0),
                            vPrecedingTaskRecordId: If(varSelectedPrecType = "Task", cbb_s4_prec_task_5.Selected.ID, 0),
                            vPrecedingSubTaskRecordId: If(varSelectedPrecType = "Sub-task", cbb_s4_prec_subtask_5.Selected.ID, 0),
                            vStartDateFinal: If(
                                varSelectedPrecType = "Manual Date",
                                dp_s4_manual_start_5.SelectedDate,
                                varV4PrecStartDate
                            ),
                            vEndDateFinal: If(
                                varSelectedPrecType = "Manual Date",
                                dp_s4_manual_end_5.SelectedDate,
                                varV4PrecEndDate
                            )
                        },
                        With(
                            {
                                vRegistroExistenteDependente: If(
                                    vIsSubTaskDependente,
                                    LookUp(
                                        col_proj_precedentes,
                                        project_id = reg_project.ID &&
                                        task_idf = vDependenteTaskIdf &&
                                        subtask_idf = vDependenteSubTaskIdf
                                    ),
                                    LookUp(
                                        col_proj_precedentes,
                                        project_id = reg_project.ID &&
                                        task_idf = vDependenteTaskIdf &&
                                        subtask_idf = 0
                                    )
                                ),
                                vSelfReference: If(
                                    varSelectedPrecType = "Task" && !vIsSubTaskDependente,
                                    vPrecedingTaskRecordId = varSelectedTaskNode.ID,
                                    If(
                                        varSelectedPrecType = "Sub-task" && vIsSubTaskDependente,
                                        vPrecedingSubTaskRecordId = varSelectedTaskNode.ID,
                                        false
                                    )
                                ),
                                vCicloDireto: If(
                                    varSelectedPrecType = "Task",
                                    !IsBlank(
                                        LookUp(
                                            col_proj_precedentes,
                                            project_id = reg_project.ID &&
                                            preceding_task_idf = varSelectedTaskNode.task_idf &&
                                            task_idf = LookUp(col_proj_ordertask, ID = vPrecedingTaskRecordId).task_idf &&
                                            subtask_idf = 0
                                        )
                                    ),
                                    If(
                                        varSelectedPrecType = "Sub-task",
                                        !IsBlank(
                                            LookUp(
                                                col_proj_precedentes,
                                                project_id = reg_project.ID &&
                                                preceding_subtask_idf = varSelectedTaskNode.ID &&
                                                subtask_idf = vPrecedingSubTaskRecordId
                                            )
                                        ),
                                        false
                                    )
                                )
                            },
                            If(
                                IsBlank(varSelectedTaskNode) || IsBlank(varSelectedTaskNode.ID),
                                Notify("Please select a dependent Task or Sub Task.", NotificationType.Warning),

                                IsBlank(varSelectedPrecType),
                                Notify("Please select a precedence type.", NotificationType.Warning),

                                varSelectedPrecType = "Task" && IsBlank(cbb_s4_prec_task_5.Selected),
                                Notify("Please select a predecessor Task.", NotificationType.Warning),

                                varSelectedPrecType = "Sub-task" && IsBlank(cbb_s4_prec_subtask_5.Selected),
                                Notify("Please select a predecessor Sub Task.", NotificationType.Warning),

                                varSelectedPrecType = "Manual Date" && (
                                    IsBlank(dp_s4_manual_start_5.SelectedDate) ||
                                    IsBlank(dp_s4_manual_end_5.SelectedDate)
                                ),
                                Notify("Please provide both start and end dates for manual precedence.", NotificationType.Warning),

                                !IsBlank(vRegistroExistenteDependente),
                                Notify("This dependent item already has a defined predecessor.", NotificationType.Warning),

                                vSelfReference,
                                Notify("An item cannot be its own predecessor.", NotificationType.Warning),

                                !IsBlank(vStartDateFinal) && !IsBlank(vEndDateFinal) && vEndDateFinal < vStartDateFinal,
                                Notify("End date cannot be earlier than start date.", NotificationType.Warning),

                                vCicloDireto,
                                Notify("Invalid relationship. A direct dependency cycle was detected.", NotificationType.Warning),

                                true,
                                With(
                                    {
                                        vPatchPrec: IfError(
                                            Patch(
                                                project_precedente_DEV,
                                                Defaults(project_precedente_DEV),
                                                {
                                                    project_id: reg_project.ID,
                                                    task_idf: vDependenteTaskIdf,
                                                    subtask_idf: vDependenteSubTaskIdf,
                                                    precedence_type: varSelectedPrecType,
                                                    preceding_task_idf: vPrecedingTaskRecordId,
                                                    preceding_subtask_idf: vPrecedingSubTaskRecordId,
                                                    StartDate: vStartDateFinal,
                                                    EndDate: vEndDateFinal
                                                }
                                            ),
                                            Blank()
                                        )
                                    },
                                    If(
                                        IsBlank(vPatchPrec),
                                        Notify("❌ Failed to save precedence.", NotificationType.Error),
                                        Notify("✅ Precedence saved successfully.", NotificationType.Success, 2500);
                                        ClearCollect(
                                            col_proj_precedentes,
                                            Filter(project_precedente_DEV, project_id = reg_project.ID)
                                        );
                                        Set(varSelectedTaskNode, Blank());
                                        Set(varSelectedPrecType, "");
                                        Set(varV4PrecStartDate, Blank());
                                        Set(varV4PrecEndDate, Blank());
                                        Reset(cbb_s4_prec_task_5);
                                        Reset(cbb_s4_prec_subtask_5);
                                        Reset(dp_s4_manual_start_5);
                                        Reset(dp_s4_manual_end_5)
                                    )
                                )
                            )
                        )
                    )
                  PressedFill: =RGBA(20, 95, 57, 0.8)
                  RadiusBottomLeft: =7
                  RadiusBottomRight: =7
                  RadiusTopLeft: =7
                  RadiusTopRight: =7
                  Size: =12
                  Text: ="＋  Add Precedence"
                  Visible: =varProjStep_ = 4
                  Width: =384
                  X: =20
                  Y: =460
            - lbl_s4_prec_added_title_5:
                Control: Text@0.0.51
                Properties:
                  FontColor: =RGBA(100, 116, 139, 1)
                  Height: =16
                  Size: =10
                  Text: ="PRECEDENCES SET"
                  Visible: =varProjStep_ = 4 && CountRows(col_proj_precedentes) > 0
                  Weight: ='TextCanvas.Weight'.Bold
                  Width: =384
                  X: =20
                  Y: =484
            - gal_s4_prec_list_5:
                Control: Gallery@2.15.0
                Variant: Vertical
                Properties:
                  BorderColor: =RGBA(226, 232, 240, 1)
                  BorderThickness: =1
                  Height: =150
                  Items: |-
                    =If(varSelectedTaskNode.ID > 0,
                        If(varSelectedTaskNode.tipo = "subtask",
                            Filter(col_proj_precedentes,
                                subtask_idf = varSelectedTaskNode.ID &&
                                task_idf = varSelectedTaskNode.task_idf),
                            Filter(col_proj_precedentes,
                                task_idf = varSelectedTaskNode.task_idf &&
                                subtask_idf = 0)
                        ),
                        col_proj_precedentes
                    )
                  LoadingSpinner: =LoadingSpinner.None
                  TemplatePadding: =2
                  TemplateSize: =36
                  Visible: =varProjStep_ = 4 && CountRows(col_proj_precedentes) > 0
                  Width: =384
                  X: =20
                  Y: =503
                Children:
                  - rect_s4_prec_row_5:
                      Control: Rectangle@2.3.0
                      Properties:
                        BorderColor: =RGBA(241, 245, 249, 1)
                        BorderThickness: =1
                        Fill: =RGBA(248, 250, 252, 1)
                        Height: =36
                        Width: =380
                  - lbl_s4_prec_type_badge_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =RGBA(0, 0, 0, 0)
                        BorderThickness: =0
                        Color: =RGBA(0, 103, 176, 1)
                        DisplayMode: =DisplayMode.View
                        Fill: =RGBA(232, 243, 251, 1)
                        FontWeight: =FontWeight.Bold
                        Height: =22
