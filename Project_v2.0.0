                              X: =532
                              Y: =10
                        - lbl_tree_card_sub_count_5:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: =RGBA(0, 0, 0, 0)
                              BorderThickness: =0
                              Color: |-
                                =If(CountRows(Filter(colSubTasksNoProject, task_idf = ThisItem.task_idf)) > 0,
                                    RGBA(0, 103, 176, 1),
                                    RGBA(148, 163, 184, 1))
                              DisplayMode: =DisplayMode.View
                              Fill: |-
                                =If(CountRows(Filter(colSubTasksNoProject, task_idf = ThisItem.task_idf)) > 0,
                                    RGBA(232, 243, 251, 1),
                                    RGBA(241, 245, 249, 1))
                              FontWeight: =FontWeight.Bold
                              Height: =20
                              RadiusBottomLeft: =20
                              RadiusBottomRight: =20
                              RadiusTopLeft: =20
                              RadiusTopRight: =20
                              Size: =9
                              Text: =Text(CountRows(Filter(colSubTasksNoProject, task_idf = ThisItem.task_idf))) & " sub"
                              Width: =50
                              X: =472
                              Y: =10
                        - btn_tree_edit_milestone_3:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: |-
                                =If(ThisItem.IsMilestone,
                                    RGBA(0, 103, 176, 1),
                                    RGBA(226, 232, 240, 1))
                              BorderThickness: =1
                              Color: |-
                                =If(ThisItem.IsMilestone,
                                    RGBA(0, 103, 176, 1),
                                    RGBA(148, 163, 184, 1))
                              Fill: |-
                                =If(ThisItem.IsMilestone,
                                    RGBA(232, 243, 251, 1),
                                    RGBA(248, 250, 252, 1))
                              Height: =22
                              HoverFill: =RGBA(232, 243, 251, 1)
                              OnSelect: |-
                                =If(
                                    IsError(Patch(Project_Tasks, ThisItem, {IsMilestone: !ThisItem.IsMilestone})),
                                    Notify("❌ Error updating Milestone.", NotificationType.Error),
                                    ClearCollect(col_proj_ordertask,
                                        Filter(Project_Tasks, project_id = reg_project.ID));
                                    Notify("✅ Milestone updated.", NotificationType.Success, 1500)
                                )
                              RadiusBottomLeft: =4
