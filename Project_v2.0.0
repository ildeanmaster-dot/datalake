                                =ClearCollect(colProjSubTasksCatalog, Filter(Sub_task, task_idf = ThisItem.task_idf));
                                Set(varSelectedTaskNode, ThisItem);

                                If(varProjStep_ = 2,
                                    Set(varEditTaskNode, ThisItem);
                                    Set(varV4TaskEndDate, ThisItem.EndDate);
                                    Set(varTogMilestone, ThisItem.IsMilestone);
                                    Set(varTogVisible, ThisItem.IsVisible),
                                    If(varProjStep_ >= 3,
                                        Set(varSelectedTaskNode, ThisItem))
                                )
                              Width: =430
                        - btn_tree_card_delete_5:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: =RGBA(0, 0, 0, 0)
                              BorderThickness: =0
                              Color: =RGBA(192, 57, 43, 1)
                              Fill: =RGBA(0, 0, 0, 0)
                              FontWeight: =FontWeight.Bold
                              Height: =26
                              HoverFill: =RGBA(253, 237, 236, 1)
                              OnSelect: |-
                                =If(
                                    CountRows(Filter(colSubTasksNoProject, task_idf = ThisItem.task_idf)) > 0,
                                    Notify("⚠️ Remove all SubTasks from this Task before deleting.", NotificationType.Warning, 3500),
                                    If(
                                        !IsBlank(LookUp(col_proj_precedentes, task_idf = ThisItem.task_idf && subtask_idf = 0)),
                                        Notify("⚠️ Remove the precedence linked to this Task before deleting.", NotificationType.Warning, 3500),
                                        If(Confirm("Remove this Task?"),
                                            If(
                                                IsError(Remove(Project_Tasks, ThisItem)),
                                                Notify("❌ Error removing Task.", NotificationType.Error),
                                                ClearCollect(col_proj_ordertask,
                                                    Filter(Project_Tasks, project_id = reg_project.ID));
                                                If(varSelectedTaskNode.ID = ThisItem.ID,
                                                    Set(varSelectedTaskNode, Blank()));
                                                Notify("✅ Task removed.", NotificationType.Success, 2000)
                                            )
                                        )
                                    )
                                )
                              PressedFill: =RGBA(253, 237, 236, 0.8)
                              RadiusBottomLeft: =5
                              RadiusBottomRight: =5
                              RadiusTopLeft: =5
                              RadiusTopRight: =5
                              Size: =11
                              Text: |-
                                ="🗑"
                              Width: =30
                              X: =565
                              Y: =54
