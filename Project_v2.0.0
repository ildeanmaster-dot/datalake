                              Size: =9
                              Text: =If(ThisItem.tipo = "subtask", "↳ " & ThisItem.subRef, "")
                              VerticalAlign: =VerticalAlign.Middle
                              Width: =340
                              X: =56
                              Y: =28
                        - lbl_prec_flat_badge_5:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: =RGBA(0, 0, 0, 0)
                              BorderThickness: =0
                              Color: |-
                                =If(!IsBlank(If(ThisItem.tipo = "subtask",
                                        LookUp(col_proj_precedentes,
                                            subtask_idf = ThisItem.ID &&
                                            task_idf = ThisItem.task_idf),
                                        LookUp(col_proj_precedentes,
                                            task_idf = ThisItem.task_idf &&
                                            subtask_idf = 0))),
                                    RGBA(26, 122, 74, 1),
                                    RGBA(148, 163, 184, 1))
                              DisplayMode: =DisplayMode.View
                              Fill: |-
                                =If(!IsBlank(If(ThisItem.tipo = "subtask",
                                        LookUp(col_proj_precedentes,
                                            subtask_idf = ThisItem.ID &&
                                            task_idf = ThisItem.task_idf),
                                        LookUp(col_proj_precedentes,
                                            task_idf = ThisItem.task_idf &&
                                            subtask_idf = 0))),
                                    RGBA(232, 245, 238, 1),
                                    RGBA(241, 245, 249, 1))
                              FontWeight: =FontWeight.Bold
                              Height: =20
                              RadiusBottomLeft: =20
                              RadiusBottomRight: =20
                              RadiusTopLeft: =20
                              RadiusTopRight: =20
                              Size: =9
                              Text: |-
                                =If(!IsBlank(If(ThisItem.tipo = "subtask",
                                        LookUp(col_proj_precedentes,
                                            subtask_idf = ThisItem.ID &&
                                            task_idf = ThisItem.task_idf),
                                        LookUp(col_proj_precedentes,
                                            task_idf = ThisItem.task_idf &&
                                            subtask_idf = 0))),
                                    "✓ Set",
                                    "Not set")
                              Width: =50
                              X: =508
                              Y: =14
                        - btn_prec_flat_delete_5:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: =RGBA(0, 0, 0, 0)
                              BorderThickness: =0
                              Color: =RGBA(192, 57, 43, 1)
                              Fill: =RGBA(0, 0, 0, 0)
                              FontWeight: =FontWeight.Bold
                              Height: =28
                              HoverFill: =RGBA(253, 237, 236, 1)
                              OnSelect: |-
                                =With(
                                    {vPrec: If(ThisItem.tipo = "subtask",
                                        LookUp(project_precedente_DEV,
                                            subtask_idf = ThisItem.ID &&
                                            task_idf = ThisItem.task_idf &&
                                            project_id = reg_project.ID),
                                        LookUp(project_precedente_DEV,
                                            subtask_idf = 0 &&
                                            task_idf = ThisItem.task_idf &&
                                            project_id = reg_project.ID))},
                                    If(!IsBlank(vPrec),
                                        If(Confirm("Remove this precedence?"),
                                            If(
                                                IsError(Remove(project_precedente_DEV, vPrec)),
                                                Notify("❌ Error removing precedence.", NotificationType.Error),
                                                ClearCollect(col_proj_precedentes,
                                                    Filter(project_precedente_DEV, project_id = reg_project.ID));
                                                If(varSelectedTaskNode.ID = ThisItem.ID,
                                                    Set(varSelectedTaskNode, Blank()));
                                                Set(varSelectedPrecType, "");
                                                Notify("✅ Precedence removed.", NotificationType.Success, 2000)
                                            )
                                        ),
                                        Notify("ℹ️ No precedence set for this item.", NotificationType.Information, 2000)
                                    )
                                )
                              PressedFill: =RGBA(253, 237, 236, 0.8)
                              RadiusBottomLeft: =5
                              RadiusBottomRight: =5
                              RadiusTopLeft: =5
                              RadiusTopRight: =5
                              Size: =11
                              Text: |-
                                ="🗑"
                              Width: =30
                              X: =568
                              Y: =10
                        - rect_prec_flat_hitbox_5:
                            Control: Rectangle@2.3.0
                            Properties:
                              BorderColor: =RGBA(0, 0, 0, 0)
                              Fill: =RGBA(0, 0, 0, 0)
                              Height: =48
                              HoverFill: =RGBA(0, 103, 176, 0.05)
                              OnSelect: |-
                                =ClearCollect(colProjPrecSubTasksCatalog, Filter(Project_SubTask, project_id = Value(reg_project.ID)));
                                ClearCollect(colProjPrecTasksCatalog, col_proj_ordertask);
                                Set(varSelectedTaskNode,
                                    {tipo: ThisItem.tipo,
                                     ID: ThisItem.ID,
                                     TaskName: If(ThisItem.tipo = "task",
                                         ThisItem.displayName,
                                         ThisItem.subRef),
                                     task_idf: ThisItem.task_idf,
                                     subtask_idf: If(ThisItem.tipo = "subtask", ThisItem.ID, 0),
                                     SubTaskName: If(ThisItem.tipo = "subtask", ThisItem.displayName, "")})
                              PressedFill: =RGBA(0, 103, 176, 0.08)
                              Width: =530
            - lbl_right_empty_state_5:
                Control: Text@0.0.51
                Properties:
                  Align: ='TextCanvas.Align'.Center
                  FontColor: =RGBA(203, 213, 225, 1)
                  Height: =80
                  Size: =12
                  Text: |-
                    =If(varProjStep_ = 3,
                        "📭" & Char(10) & "No SubTasks yet. Select a task and add SubTasks.",
                        "🗂" & Char(10) & "No tasks yet. Use the form to add the first task.")
                  VerticalAlign: =VerticalAlign.Middle
                  Visible: |-
                    =(varProjStep_ >= 2 && varProjStep_ <> 4 &&
                        CountRows(Filter(Project_Tasks, project_id = reg_project.ID)) = 0) ||
                    (varProjStep_ = 3 &&
                        CountRows(colSubTasksNoProject) = 0)
                  Width: =615
                  X: =435
                  Y: =280
            - cnt_footer_3:
                Control: GroupContainer@1.5.0
                Variant: ManualLayout
                Properties:
                  BorderColor: =RGBA(226, 232, 240, 1)
                  BorderThickness: =1
                  Fill: =RGBA(248, 250, 252, 1)
                  Height: =52
                  Width: =cnt_popup_34.Width
                  Y: =cnt_popup_34.Height - Self.Height
                Children:
                  - btn_footer_gantt_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =RGBA(226, 232, 240, 1)
                        BorderThickness: =1.5
                        Color: =If(reg_project.ID > 0 && varProjectMode = "edit", RGBA(51, 65, 85, 1), RGBA(148, 163, 184, 1))
                        DisabledBorderColor: =RGBA(226, 232, 240, 1)
                        DisabledColor: =RGBA(148, 163, 184, 1)
                        DisabledFill: =RGBA(248, 250, 252, 1)
                        DisplayMode: =If(reg_project.ID > 0 && varProjectMode = "edit", DisplayMode.Edit, DisplayMode.Disabled)
                        Fill: =RGBA(255, 255, 255, 1)
                        Font: =Font.'Open Sans'
                        Height: =32
                        HoverBorderColor: =RGBA(148, 163, 184, 1)
                        HoverFill: =RGBA(248, 250, 252, 1)
                        OnSelect: =Set(varViewTask, true)
                        RadiusBottomLeft: =6
                        RadiusBottomRight: =6
                        RadiusTopLeft: =6
                        RadiusTopRight: =6
                        Size: =12
                        Text: |-
                          ="📊  Gantt Chart"
                        Width: =140
                        X: =20
                        Y: =10
                  - btn_footer_masterplan_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =RGBA(226, 232, 240, 1)
                        BorderThickness: =1.5
                        Color: =RGBA(51, 65, 85, 1)
                        DisabledBorderColor: =RGBA(226, 232, 240, 1)
                        DisabledColor: =RGBA(148, 163, 184, 1)
                        DisabledFill: =RGBA(248, 250, 252, 1)
                        DisplayMode: =If(reg_project.ID > 0 && varProjectMode = "edit", DisplayMode.Edit, DisplayMode.Disabled)
                        Fill: =RGBA(255, 255, 255, 1)
                        Font: =Font.'Open Sans'
                        Height: =32
                        HoverBorderColor: =RGBA(148, 163, 184, 1)
                        HoverFill: =RGBA(248, 250, 252, 1)
                        OnSelect: =Notify("Master Plan — coming soon", NotificationType.Information, 2000)
                        RadiusBottomLeft: =6
                        RadiusBottomRight: =6
                        RadiusTopLeft: =6
                        RadiusTopRight: =6
                        Size: =12
                        Text: |-
                          ="📋  Master Plan"
                        Width: =140
                        X: =170
                        Y: =10
                  - btn_footer_close_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =RGBA(226, 232, 240, 1)
                        BorderThickness: =1.5
                        Color: =RGBA(51, 65, 85, 1)
                        Fill: =RGBA(255, 255, 255, 1)
                        Font: =Font.'Open Sans'
                        FontWeight: =FontWeight.Bold
                        Height: =32
                        HoverBorderColor: =RGBA(148, 163, 184, 1)
                        HoverFill: =RGBA(248, 250, 252, 1)
                        OnSelect: |-
                          =Set(varCompositionOpen, false);
                          Set(varProjectMode, "");
                          Set(varProjStep_, 1);
                          Set(varSelectedTaskNode, Blank());
                          Set(varEditTaskNode, Blank());
                          Set(varSelectedPrecType, "");
                          Set(varV4View, "tree")
                        RadiusBottomLeft: =6
                        RadiusBottomRight: =6
                        RadiusTopLeft: =6
                        RadiusTopRight: =6
                        Size: =12
                        Text: ="Close"
                        Width: =100
                        X: =840
                        Y: =10
                  - btn_footer_next_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =ColorFade(Self.Fill, -15%)
                        Color: =RGBA(255, 255, 255, 1)
                        Fill: =RGBA(0, 103, 176, 1)
                        Font: =Font.'Open Sans'
                        FontWeight: =FontWeight.Bold
                        Height: =32
                        HoverFill: =RGBA(0, 74, 128, 1)
                        OnSelect: |-
                          =If(varProjStep_ = 1,
                              If(
                                  IsBlank(txt_s0_name_3.Text) ||
                                  IsBlank(cbb_s0_status_3.Selected) ||
                                  IsBlank(cbb_s0_bu_3.Selected) ||
                                  IsBlank(cbb_s0_type_3.Selected) ||
                                  IsBlank(cbb_s0_template_3.Selected) ||
                                  IsBlank(txt_s0_customer_2.Text) ||
                                  IsBlank(dp_s0_start_date_3.SelectedDate) ||
                                  IsBlank(dp_s0_end_date_3.SelectedDate),
                                  Notify("⚠️ Fill in all required fields before proceeding.", NotificationType.Warning, 3000),
                                  With(
                                      {rProj: IfError(
                                          Patch(Project,
                                              If(varProjectMode = "edit",
                                                  LookUp(Project, ID = reg_project.ID),
                                                  Defaults(Project)),
                                              {
                                                  Name: txt_s0_name_3.Text,
                                                  Customer: txt_s0_customer_2.Text,
                                                  Status: cbb_s0_status_3.Selected.Value,
                                                  BusinessUnit_ID: cbb_s0_bu_3.Selected.ID,
                                                  Project_Type: cbb_s0_type_3.Selected.Value,
                                                  Template: cbb_s0_template_3.Selected.Name,
                                                  Aircraft: Coalesce(cbb_s0_aircraft_3.Selected.Aircraft, Blank()),
                                                  Aircraft1: Coalesce(cbb_s0_aircraft_4.Selected.Aircraft, Blank()),
                                                  StartDate: dp_s0_start_date_3.SelectedDate,
                                                  EndDate: dp_s0_end_date_3.SelectedDate,
                                                  Country: txt_s0_country_3.Text,
                                                  Site: txt_s0_site_3.Text,
                                                  Lessor: txt_s0_lessor_3.Text,
                                                  EIS_manager: cbb_s0_eis_manager_3.Selected.DisplayName,
                                                  CAM: cbb_s0_cam_3.Selected.DisplayName,
                                                  EIS_date: dp_s0_eis_date_3.SelectedDate,
                                                  LOA_date: dp_s0_loa_date_3.SelectedDate,
                                                  PA_date: dp_s0_pa_date_3.SelectedDate
                                                  //logo: If(!IsBlank(txt_s0_logo_url_1.Text); txt_s0_logo_url_1.Text; reg_project.logo)
                                              }
                                          ),
                                          Blank()
                                      )},
                                      If(IsBlank(rProj),
                                          Notify("❌ Error saving project.", NotificationType.Error),
                                          Set(reg_project, rProj);
                                          If(
                                              varProjectMode = "new" && !IsBlank(cbb_s0_template_3.Selected),
                                              ClearCollect(colTplProjTasks, Filter(Template_Task, template_idf = cbb_s0_template_3.Selected.ID));
                                              ClearCollect(colTplProjSubs, Filter(Template_SubTask, template_idf = cbb_s0_template_3.Selected.ID));
                                              ClearCollect(colTplProjPrecs, Filter(Template_Precedente_DEV, template_idf = cbb_s0_template_3.Selected.ID));
                                              Clear(colMapProjTask);
                                              Clear(colMapProjSub);
                                              With(
                                                  {
                                                      vTplStart: Min(colTplProjTasks, StartDate),
                                                      vTplEnd: Max(colTplProjTasks, EndDate),
                                                      vScaleFactor: If(
                                                          DateDiff(Min(colTplProjTasks, StartDate), Max(colTplProjTasks, EndDate), TimeUnit.Days) <= 0,
                                                          1,
                                                          DateDiff(dp_s0_start_date_3.SelectedDate, dp_s0_end_date_3.SelectedDate, TimeUnit.Days) /
                                                          DateDiff(Min(colTplProjTasks, StartDate), Max(colTplProjTasks, EndDate), TimeUnit.Days)
                                                      )
                                                  },
                                                  ForAll(
                                                      colTplProjTasks As recTask,
                                                      With(
                                                          {
                                                              vNewTask: Patch(
                                                                  Project_Tasks,
                                                                  Defaults(Project_Tasks),
                                                                  {
                                                                      project_name: rProj.Name,
                                                                      functional_area: recTask.functional_area,
                                                                      functional_area_id: recTask.functional_area_id,
                                                                      project_id: rProj.ID,
                                                                      TaskName: recTask.TaskName,
                                                                      task_idf: recTask.task_idf,
                                                                      OrdemTask: recTask.OrdemTask,
                                                                      StartDate: If(
                                                                          !IsBlank(recTask.StartDate),
                                                                          Max(
                                                                              dp_s0_start_date_3.SelectedDate,
                                                                              DateAdd(
                                                                                  dp_s0_start_date_3.SelectedDate,
                                                                                  RoundDown(DateDiff(vTplStart, recTask.StartDate, TimeUnit.Days) * vScaleFactor, 0),
                                                                                  TimeUnit.Days
                                                                              )
                                                                          ),
                                                                          dp_s0_start_date_3.SelectedDate
                                                                      ),
                                                                      EndDate: If(
                                                                          !IsBlank(recTask.EndDate),
                                                                          Min(
                                                                              dp_s0_end_date_3.SelectedDate,
                                                                              DateAdd(
                                                                                  dp_s0_start_date_3.SelectedDate,
                                                                                  RoundDown(DateDiff(vTplStart, recTask.EndDate, TimeUnit.Days) * vScaleFactor, 0),
                                                                                  TimeUnit.Days
                                                                              )
                                                                          ),
                                                                          dp_s0_end_date_3.SelectedDate
                                                                      ),
                                                                      IsMilestone: recTask.IsMilestone,
                                                                      IsVisible: recTask.IsVisible,
                                                                      Status: recTask.Status
                                                                  }
                                                              )
                                                          },
                                                          Collect(
                                                              colMapProjTask,
                                                              {
                                                                  OldTaskListID: recTask.ID,
                                                                  OldTaskIDF: recTask.task_idf,
                                                                  NewTaskListID: vNewTask.ID,
                                                                  NewTaskIDF: vNewTask.task_idf
                                                              }
                                                          )
                                                      )
                                                  );
                                                  ForAll(
                                                      colTplProjSubs As recSub,
                                                      With(
                                                          {
                                                              vNewSub: Patch(
                                                                  Project_SubTask,
                                                                  Defaults(Project_SubTask),
                                                                  {
                                                                      SubTaskName: recSub.SubTaskName,
                                                                      SubTask_id: recSub.subtask_idf,
                                                                      durationindays: recSub.durationindays,
                                                                      StartDate: If(
                                                                          !IsBlank(recSub.StartDate),
                                                                          Max(
                                                                              dp_s0_start_date_3.SelectedDate,
                                                                              DateAdd(
                                                                                  dp_s0_start_date_3.SelectedDate,
                                                                                  RoundDown(DateDiff(vTplStart, recSub.StartDate, TimeUnit.Days) * vScaleFactor, 0),
                                                                                  TimeUnit.Days
                                                                              )
                                                                          ),
                                                                          dp_s0_start_date_3.SelectedDate
                                                                      ),
                                                                      EndDate: If(
                                                                          !IsBlank(recSub.EndDate),
                                                                          Min(
                                                                              dp_s0_end_date_3.SelectedDate,
                                                                              DateAdd(
                                                                                  dp_s0_start_date_3.SelectedDate,
                                                                                  RoundDown(DateDiff(vTplStart, recSub.EndDate, TimeUnit.Days) * vScaleFactor, 0),
                                                                                  TimeUnit.Days
                                                                              )
                                                                          ),
                                                                          dp_s0_end_date_3.SelectedDate
                                                                      ),
                                                                      function_area_idf: recSub.function_area_idf,
                                                                      project_id: rProj.ID,
                                                                      task_idf: Coalesce(
                                                                          LookUp(colMapProjTask, OldTaskIDF = recSub.task_idf, NewTaskIDF),
                                                                          0
                                                                      ),
                                                                      OrdemSubTask: recSub.OrdemSubTask,
                                                                      Status: recSub.Status
                                                                  }
                                                              )
                                                          },
                                                          Collect(
                                                              colMapProjSub,
                                                              {
                                                                  OldSubTaskListID: recSub.ID,
                                                                  OldSubTaskIDF: recSub.subtask_idf,
                                                                  NewSubTaskListID: vNewSub.ID,
                                                                  NewSubTaskIDF: vNewSub.SubTask_id
                                                              }
                                                          )
                                                      )
                                                  );
                                                  ForAll(
                                                      colTplProjPrecs As recPrec,
                                                      Patch(
                                                          project_precedente_DEV,
                                                          Defaults(project_precedente_DEV),
                                                          {
                                                              project_id: rProj.ID,
                                                              task_idf: Coalesce(
                                                                  LookUp(colMapProjTask, OldTaskIDF = recPrec.task_idf, NewTaskIDF),
                                                                  0
                                                              ),
                                                              subtask_idf: Coalesce(
                                                                  LookUp(colMapProjSub, OldSubTaskIDF = recPrec.subtask_idf, NewSubTaskIDF),
                                                                  0
                                                              ),
                                                              precedence_type: recPrec.precedence_type,
                                                              preceding_task_idf: Coalesce(
                                                                  LookUp(colMapProjTask, OldTaskListID = recPrec.preceding_task_idf, NewTaskListID),
                                                                  0
                                                              ),
                                                              preceding_subtask_idf: Coalesce(
                                                                  LookUp(colMapProjSub, OldSubTaskListID = recPrec.preceding_subtask_idf, NewSubTaskListID),
                                                                  0
                                                              ),
                                                              StartDate: recPrec.StartDate,
                                                              EndDate: recPrec.EndDate
                                                          }
                                                      )
                                                  )
                                              );
                                              ClearCollect(col_proj_ordertask, Filter(Project_Tasks, project_id = rProj.ID));
                                              ClearCollect(colSubTasksNoProject, Filter(Project_SubTask, project_id = rProj.ID));
                                              ClearCollect(col_proj_precedentes, Filter(project_precedente_DEV, project_id = rProj.ID))
                                          );
                                          Notify("✅ Project saved! Now add tasks.", NotificationType.Success, 2500);
                                          Set(varProjStep_, 2);
                                          Set(varSelectedTaskNode, Blank());
                                          Set(varEditTaskNode, Blank())
                                      )
                                  )
                              ),
                              If(varProjStep_ = 2,
                                  If(!IsBlank(varEditTaskNode),
                                      Notify("⚠️ Finish editing the selected task first.", NotificationType.Warning, 3000),
                                      If(CountRows(Filter(Project_Tasks, project_id = reg_project.ID)) = 0,
                                          Notify("⚠️ Add at least one Task before proceeding.", NotificationType.Warning, 3000),
                                          Set(varProjStep_, 3);
                                          Set(varSelectedTaskNode, Blank())
                                      )
                                  ),
                                  If(varProjStep_ = 3,
                                      Set(varProjStep_, 4);
                                      ClearCollect(col_proj_precflat,
                                          AddColumns(col_proj_ordertask,
                                              tipo, "task",
                                              displayName, TaskName,
                                              ordemSort, OrdemTask * 100,
                                              subRef, ""));
                                      Collect(col_proj_precflat,
                                          AddColumns(colSubTasksNoProject,
                                              tipo, "subtask",
                                              displayName, SubTaskName,
                                              ordemSort, LookUp(col_proj_ordertask, task_idf = task_idf).OrdemTask * 100 + OrdemSubTask,
                                              subRef, LookUp(col_proj_ordertask, task_idf = task_idf).TaskName));
                                      Set(varSelectedTaskNode, Blank());
                                      Set(varSelectedPrecType, ""),
                                      Notify("✅ Project composition saved!", NotificationType.Success, 2500);
                                      Set(varCompositionOpen, false);
                                      Set(varProjectMode, "");
                                      Set(varProjStep_, 1);
                                      Set(varEditTaskNode, Blank());
                                      Set(varV4View, "tree")
                                  )
                              )
                          )
                        PressedFill: =RGBA(0, 74, 128, 0.8)
                        RadiusBottomLeft: =6
                        RadiusBottomRight: =6
                        RadiusTopLeft: =6
                        RadiusTopRight: =6
                        Size: =12
                        Text: |-
                          =Switch(varProjStep_,
                              1, "Save & Go to Tasks  →",
                              2, "Go to SubTasks  →",
                              3, "Go to Precedences  →",
                              4, "✅  Finish"
                          )
                        Width: =200
                        X: =840
                        Y: =10
            - cbb_s2_functional_area_5:
                Control: Classic/ComboBox@2.4.0
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  DisplayFields: =["NameArea"]
                  FocusedBorderColor: =RGBA(0, 103, 176, 1)
                  FocusedBorderThickness: =2
                  Font: =Font.'Open Sans'
                  Height: =38
                  InputTextPlaceholder: ="Select…"
                  Items: |-
                    =Filter(AreaFuncional,
                        BusinessUnit_ID = reg_project.BusinessUnit_ID
                    )
                  OnChange: =Reset(cbb_s2_task_5)
                  SearchFields: =["NameArea"]
                  SelectMultiple: =false
                  Visible: =varProjStep_ = 2
                  Width: =384
                  X: =20
                  Y: =284
            - cbb_s3_subtask_5:
                Control: Classic/ComboBox@2.4.0
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  DisplayFields: =["description"]
                  DisplayMode: =If(varSelectedTaskNode.ID = 0, DisplayMode.Disabled, DisplayMode.Edit)
                  FocusedBorderColor: =RGBA(0, 103, 176, 1)
                  FocusedBorderThickness: =2
                  Font: =Font.'Open Sans'
                  Height: =38
                  InputTextPlaceholder: ="Select task first…"
                  IsSearchable: =false
                  Items: |-
                    =Filter(
                        colProjSubTasksCatalog,
                        task_idf = varSelectedTaskNode.task_idf
                        && !IsBlank(name)
                        && !(ID in colSubTasksNoProject.SubTask_id)
                    )
                  OnChange: |-
                    =If(
                        !IsBlank(Self.Selected) && !IsBlank(dp_s3_start_date_5.SelectedDate),
                        Set(varV4SubEndDate,
                            DateAdd(dp_s3_start_date_5.SelectedDate,
                                Self.Selected.durationindays - 1,
                                TimeUnit.Days))
                    )
                  SearchFields: =[""]
                  SelectMultiple: =false
                  Visible: =varProjStep_ = 3
                  Width: =384
                  X: =20
                  Y: =292
            - dp_s3_start_date_5:
                Control: DatePicker@0.0.46
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  DisplayMode: =If(varSelectedTaskNode.ID = 0, DisplayMode.Disabled, DisplayMode.Edit)
                  Format: =DateTimeFormat.ShortDate
                  Height: =38
                  OnChange: |-
                    =If(
                        !IsBlank(Self.SelectedDate),
                        If(
                            !IsBlank(varSelectedTaskNode.StartDate) &&
                            Self.SelectedDate < varSelectedTaskNode.StartDate,
                            Notify(
                                "⚠️ SubTask start is before the Task start (" &
                                Text(varSelectedTaskNode.StartDate, "dd/mm/yyyy") & ").",
                                NotificationType.Warning,
                                3500
                            )
                        );
                        If(
                            !IsBlank(cbb_s3_subtask_5.Selected),
                            Set(varV4SubEndDate,
                                DateAdd(Self.SelectedDate,
                                    cbb_s3_subtask_5.Selected.durationindays - 1,
                                    TimeUnit.Days)
                            )
                        )
                    )
                  SelectedDate: =varSelectedTaskNode.StartDate
                  Visible: =varProjStep_ = 3
                  Width: =185
                  X: =20
                  Y: =362
            - dp_s3_end_date_5:
                Control: DatePicker@0.0.46
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  DisplayMode: =If(varSelectedTaskNode.ID = 0, DisplayMode.Disabled, DisplayMode.Edit)
                  Format: =DateTimeFormat.ShortDate
                  Height: =38
                  OnChange: |-
                    =If(
                        !IsBlank(Self.SelectedDate),
                        If(
                            !IsBlank(varSelectedTaskNode.EndDate) &&
                            Self.SelectedDate > varSelectedTaskNode.EndDate,
                            Notify(
                                "⚠️ SubTask end exceeds the Task end (" &
                                Text(varSelectedTaskNode.EndDate, "dd/mm/yyyy") & ").",
                                NotificationType.Warning,
                                3500
                            )
                        );
                        If(
                            !IsBlank(dp_s3_start_date_5.SelectedDate) &&
                            Self.SelectedDate < dp_s3_start_date_5.SelectedDate,
                            Notify(
                                "⚠️ End date cannot be before Start date.",
                                NotificationType.Warning,
                                3000
                            )
                        )
                    )
                  SelectedDate: =Coalesce(varV4SubEndDate, varSelectedTaskNode.EndDate)
                  Visible: =varProjStep_ = 3
                  Width: =185
                  X: =219
                  Y: =362
            - cbb_s4_prec_task_5:
                Control: Classic/ComboBox@2.4.0
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  DisplayFields: =["TaskName"]
                  FocusedBorderColor: =RGBA(0, 103, 176, 1)
                  FocusedBorderThickness: =2
                  Font: =Font.'Open Sans'
                  Height: =38
                  InputTextPlaceholder: ="Select…"
                  Items: |-
                    =Filter(
                        colProjPrecTasksCatalog,
                        ID <> varSelectedTaskNode.ID
                        && !(ID in col_proj_precedentes.preceding_task_idf)
                    )
                  OnChange: |-
                    =If(!IsBlank(Self.Selected),
                        With(
                            {vStart: DateAdd(Self.Selected.EndDate, 1, TimeUnit.Days),
                             vDur: If(varSelectedTaskNode.tipo = "subtask",
                                 Coalesce(LookUp(colSubTasksNoProject,
                                     ID = varSelectedTaskNode.subtask_idf).durationindays, 1),
                                 Coalesce(LookUp(col_proj_ordertask,
                                     ID = varSelectedTaskNode.ID).DurationInDays, 1))},
                            Set(varV4PrecStartDate, vStart);
                            Set(varV4PrecEndDate,
                                DateAdd(vStart, vDur - 1, TimeUnit.Days))
                        )
                    )
                  SearchFields: =["TaskName"]
                  SelectMultiple: =false
                  Visible: =varProjStep_ = 4 && varSelectedPrecType = "Task"
                  Width: =384
                  X: =20
                  Y: =380
            - cbb_s4_prec_subtask_5:
                Control: Classic/ComboBox@2.4.0
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  DisplayFields: =["SubTaskName"]
                  FocusedBorderColor: =RGBA(0, 103, 176, 1)
                  FocusedBorderThickness: =2
                  Font: =Font.'Open Sans'
                  Height: =38
                  InputTextPlaceholder: ="Select…"
                  Items: |-
                    =AddColumns(
                        Filter(
                            colProjPrecSubTasksCatalog,
                            !(ID in col_proj_precedentes.preceding_subtask_idf)
                        ),
                        SubTaskLabel,
                        SubTaskName & " " & Char(183) & " " & LookUp(col_proj_ordertask, ID = task_idf).TaskName
                    )
                  OnChange: |-
                    =If(!IsBlank(Self.Selected),
                        With(
                            {vStart: DateAdd(LookUp(colSubTasksNoProject,
                                 ID = Self.Selected.ID).EndDate, 1, TimeUnit.Days),
                             vDur: If(varSelectedTaskNode.tipo = "subtask",
                                 Coalesce(LookUp(colSubTasksNoProject,
                                     ID = varSelectedTaskNode.subtask_idf).durationindays, 1),
                                 Coalesce(LookUp(col_proj_ordertask,
                                     ID = varSelectedTaskNode.ID).DurationInDays, 1))},
                            Set(varV4PrecStartDate, vStart);
                            Set(varV4PrecEndDate,
                                DateAdd(vStart, vDur - 1, TimeUnit.Days))
                        )
                    )
                  SearchFields: =["SubTaskName"]
                  SelectMultiple: =false
                  Visible: =varProjStep_ = 4 && varSelectedPrecType = "Sub-task"
                  Width: =384
                  X: =20
                  Y: =380
            - dp_s4_manual_start_5:
                Control: DatePicker@0.0.46
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  Format: =DateTimeFormat.ShortDate
                  Height: =38
                  OnChange: |-
                    =If(
                        !IsBlank(Self.SelectedDate) && varSelectedTaskNode.ID > 0,
                        Set(varV4PrecStartDate, Self.SelectedDate);
                        Set(varV4PrecEndDate,
                            DateAdd(Self.SelectedDate,
                                If(varSelectedTaskNode.tipo = "subtask",
                                    Coalesce(LookUp(colSubTasksNoProject,
                                        ID = varSelectedTaskNode.subtask_idf).durationindays, 1),
                                    Coalesce(LookUp(col_proj_ordertask,
                                        ID = varSelectedTaskNode.ID).DurationInDays, 1)) - 1,
                                TimeUnit.Days))
                    )
                  SelectedDate: =varV4PrecStartDate
                  Visible: =varProjStep_ = 4 && varSelectedPrecType = "Manual Date"
                  Width: =185
                  X: =20
                  Y: =380
            - dp_s4_manual_end_5:
                Control: DatePicker@0.0.46
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  Format: =DateTimeFormat.ShortDate
                  Height: =38
                  OnChange: |-
                    =If(
                        !IsBlank(Self.SelectedDate),
                        If(Self.SelectedDate > reg_project.EndDate,
                            Notify("End date exceeds the project limit.", NotificationType.Warning, 3000);
                            Reset(Self),
                            If(!IsBlank(dp_s4_manual_start_5.SelectedDate) &&
                               Self.SelectedDate < dp_s4_manual_start_5.SelectedDate,
                                Notify("End date cannot be earlier than start date.", NotificationType.Warning, 3000);
                                Reset(Self)
                            )
                        )
                    )
                  SelectedDate: =varV4PrecEndDate
                  Visible: =varProjStep_ = 4 && varSelectedPrecType = "Manual Date"
                  Width: =185
                  X: =219
                  Y: =380
            - cbb_s2_task_5:
                Control: Classic/ComboBox@2.4.0
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  DisplayFields: =["Name"]
                  DisplayMode: =If(IsBlank(cbb_s2_functional_area_5.Selected), DisplayMode.Disabled, DisplayMode.Edit)
                  FocusedBorderColor: =RGBA(0, 103, 176, 1)
                  FocusedBorderThickness: =2
                  Font: =Font.'Open Sans'
                  Height: =38
                  InputTextPlaceholder: ="Select…"
                  IsSearchable: =false
                  Items: |-
                    =Filter(
                        Tasks_processs,
                        FunctionalArea_Name = cbb_s2_functional_area_5.Selected.NameArea
                        && !(ID in col_proj_ordertask.task_idf)
                    )
                  OnChange: |-
                    =If(
                        !IsBlank(cbb_s2_task_5.Selected),
                        Set(varV4TaskEndDate,
                            DateAdd(dp_s2_start_date_5.SelectedDate,
                                cbb_s2_task_5.Selected.DurationInDays - 1,
                                TimeUnit.Days))
                    )
                  SearchFields: =[""]
                  SelectMultiple: =false
                  Visible: =varProjStep_ = 2
                  Width: =384
                  X: =20
                  Y: =352
            - dp_s2_start_date_5:
                Control: DatePicker@0.0.46
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  Format: =DateTimeFormat.ShortDate
                  Height: =38
                  OnChange: |-
                    =If(
                        !IsBlank(Self.SelectedDate),
                        If(
                            Self.SelectedDate < reg_project.StartDate,
                            Notify(
                                "⚠️ Start date is before the project start (" &
                                Text(reg_project.StartDate, "dd/mm/yyyy") & ").",
                                NotificationType.Warning,
                                3500
                            )
                        );
                        If(
                            !IsBlank(dp_s2_end_date_5.SelectedDate) &&
                            Self.SelectedDate > dp_s2_end_date_5.SelectedDate,
                            Notify(
                                "⚠️ Start date cannot be after End date.",
                                NotificationType.Warning,
                                3000
                            )
                        )
                    )
                  SelectedDate: =If(!IsBlank(varEditTaskNode), varEditTaskNode.StartDate, reg_project.StartDate)
                  Visible: =varProjStep_ = 2
                  Width: =185
                  X: =20
                  Y: =420
            - dp_s2_end_date_5:
                Control: DatePicker@0.0.46
                Properties:
                  BorderColor: =RGBA(203, 213, 225, 1)
                  Format: =DateTimeFormat.ShortDate
                  Height: =38
                  OnChange: |-
                    =If(
                        !IsBlank(Self.SelectedDate),
                        If(
                            Self.SelectedDate > reg_project.EndDate,
                            Notify(
                                "⚠️ End date exceeds the project end (" &
                                Text(reg_project.EndDate, "dd/mm/yyyy") & ").",
                                NotificationType.Warning,
                                3500
                            )
                        );
                        If(
                            !IsBlank(dp_s2_start_date_5.SelectedDate) &&
                            Self.SelectedDate < dp_s2_start_date_5.SelectedDate,
                            Notify(
                                "⚠️ End date cannot be before Start date.",
                                NotificationType.Warning,
                                3000
                            )
                        );
                        If(
                            !IsBlank(cbb_s2_task_5.Selected) &&
                            !IsBlank(dp_s2_start_date_5.SelectedDate),
                            Set(varV4TaskEndDate,
                                DateAdd(dp_s2_start_date_5.SelectedDate,
                                    cbb_s2_task_5.Selected.DurationInDays - 1,
                                    TimeUnit.Days)
                            )
                        )
                    )
                  SelectedDate: =If(!IsBlank(varEditTaskNode), varEditTaskNode.EndDate, varV4TaskEndDate)
                  Visible: =varProjStep_ = 2
                  Width: =185
                  X: =219
                  Y: =420
      - btn_test_new_6:
          Control: Classic/Button@2.2.0
          Properties:
            Color: =RGBA(255, 255, 255, 1)
            Fill: =RGBA(0, 103, 176, 1)
            Font: =Font.'Open Sans'
            FontWeight: =FontWeight.Bold
            Height: =36
            HoverFill: =RGBA(0, 74, 128, 1)
            OnSelect: |-
              =Set(reg_project, First(Project));
              Set(reg_project, Blank());
              Set(varProjectMode, "new");
              Set(varCompositionOpen, true);
              Navigate(Project_v2_5, ScreenTransition.Fade)
            RadiusBottomLeft: =8
            RadiusBottomRight: =8
            RadiusTopLeft: =8
            RadiusTopRight: =8
            Size: =13
            Text: ="＋  New Project"
            Visible: =false
            Width: =200
            X: =40
            Y: =40
      - btn_test_edit_5:
          Control: Classic/Button@2.2.0
          Properties:
            Color: =RGBA(255, 255, 255, 1)
            Fill: =RGBA(26, 122, 74, 1)
            Font: =Font.'Open Sans'
            FontWeight: =FontWeight.Bold
            Height: =36
            HoverFill: =RGBA(20, 95, 57, 1)
            OnSelect: |-
              =Set(reg_project, LookUp(Project, ID = 285));
              Set(varProjectMode, "edit");
              Set(varCompositionOpen, true);
              Navigate(Project_v2_5, ScreenTransition.Fade)
            RadiusBottomLeft: =8
            RadiusBottomRight: =8
            RadiusTopLeft: =8
            RadiusTopRight: =8
            Size: =13
            Text: ="✏  Edit Project (ID 285)"
            Visible: =false
            Width: =220
            X: =40
            Y: =115
