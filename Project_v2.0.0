                  Text: |-
                    ="📭" & Char(10) & "No subtasks added yet. Select a task on the right."
                  VerticalAlign: =VerticalAlign.Middle
                  Visible: =varProjStep_ = 3 && CountRows(colSubTasksNoProject) = 0
                  Width: =615
                  X: =435
