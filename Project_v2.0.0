            - lbl_s3_end_date_5:
                Control: Text@0.0.51
                Properties:
                  FontColor: =RGBA(100, 116, 139, 1)
                  Height: =16
                  Size: =10
                  Text: ="END DATE  *"
                  Visible: =varProjStep_ = 3
                  Weight: ='TextCanvas.Weight'.Bold
                  Width: =185
                  X: =219
                  Y: =344
            - btn_s3_add_subtask_5:
                Control: Classic/Button@2.2.0
                Properties:
                  BorderColor: =ColorFade(Self.Fill, -15%)
                  Color: =RGBA(255, 255, 255, 1)
                  DisabledBorderColor: =RGBA(214, 221, 224, 1)
                  DisabledFill: =RGBA(214, 221, 224, 1)
                  DisplayMode: |-
                    =If(
                        varSelectedTaskNode.ID = 0 ||
                        IsBlank(cbb_s3_subtask_5.Selected) ||
                        IsBlank(dp_s3_start_date_5.SelectedDate) ||
                        IsBlank(dp_s3_end_date_5.SelectedDate),
                        DisplayMode.Disabled,
                        DisplayMode.Edit
                    )
                  Fill: =RGBA(26, 122, 74, 1)
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =36
                  HoverFill: =RGBA(20, 95, 57, 1)
                  OnSelect: |-
                    =With(
                        {
                            vNextOrderSub: CountRows(Filter(Project_SubTask,
                                task_idf = varSelectedTaskNode.task_idf)) + 1
                        },
                        If(
                            IsError(Patch(Project_SubTask, Defaults(Project_SubTask), {
                                SubTaskName: cbb_s3_subtask_5.Selected.name,
                                SubTask_id: cbb_s3_subtask_5.Selected.ID,
                                durationindays: cbb_s3_subtask_5.Selected.durationindays,
                                StartDate: dp_s3_start_date_5.SelectedDate,
                                EndDate: dp_s3_end_date_5.SelectedDate,
                                function_area_idf: varSelectedTaskNode.functional_area_id,
                                project_id: reg_project.ID,
                                task_idf: varSelectedTaskNode.task_idf,
                                OrdemSubTask: vNextOrderSub,
                                Status: { Value: "Active" }
                            })),
                            Notify("❌ Error creating SubTask.", NotificationType.Error),
                            Notify("✅ SubTask added successfully!", NotificationType.Success, 2500);
                            Reset(cbb_s3_subtask_5);
                            Reset(dp_s3_start_date_5);
                            Reset(dp_s3_end_date_5);
                            ClearCollect(colSubTasksNoProject,
                                Filter(Project_SubTask, project_id = reg_project.ID))
                        )
                    )
                  PressedFill: =RGBA(20, 95, 57, 0.8)
                  RadiusBottomLeft: =7
                  RadiusBottomRight: =7
                  RadiusTopLeft: =7
                  RadiusTopRight: =7
                  Size: =12
                  Text: ="＋  Add SubTask"
                  Visible: =varProjStep_ = 3
                  Width: =384
                  X: =20
                  Y: =420
            - lbl_s3_subtasks_added_title_5:
                Control: Text@0.0.51
                Properties:
                  FontColor: =RGBA(100, 116, 139, 1)
                  Height: =16
                  Size: =10
