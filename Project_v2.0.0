                        X: =6
                        Y: =7
                  - lbl_s4_prec_name_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(15, 23, 42, 1)
                        Height: =36
                        Size: =11
                        Text: |-
                          =If(ThisItem.precedence_type = "Task",
                              Coalesce(
                                  LookUp(col_proj_ordertask, task_idf = ThisItem.preceding_task_idf, TaskName),
                                  LookUp(col_proj_ordertask, ID = ThisItem.preceding_task_idf, TaskName),
                                  "—"
                              ),
                              If(ThisItem.precedence_type = "Sub-task",
                                  Coalesce(
                                      LookUp(colSubTasksNoProject, SubTask_id = ThisItem.preceding_subtask_idf, SubTaskName),
                                      LookUp(colSubTasksNoProject, ID = ThisItem.preceding_subtask_idf, SubTaskName),
                                      "—"
                                  ),
                                  Text(ThisItem.StartDate, "dd/mm/yyyy") & " → " & Text(ThisItem.EndDate, "dd/mm/yyyy")
                              )
                          )
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =240
                        X: =84
                  - btn_s4_prec_row_delete_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =RGBA(0, 0, 0, 0)
                        BorderThickness: =0
                        Color: =RGBA(192, 57, 43, 1)
                        Fill: =RGBA(0, 0, 0, 0)
                        FontWeight: =FontWeight.Bold
                        Height: =36
                        HoverFill: =RGBA(253, 237, 236, 1)
                        OnSelect: |-
                          =If(Confirm("Remove this precedence?"),
                              If(
                                  IsError(Remove(project_precedente_DEV, ThisItem)),
                                  Notify("❌ Error removing precedence.", NotificationType.Error),
                                  ClearCollect(col_proj_precedentes,
                                      Filter(project_precedente_DEV, project_id = reg_project.ID));
                                  Notify("✅ Precedence removed.", NotificationType.Success, 2000)
                              )
                          )
                        PressedFill: =RGBA(253, 237, 236, 0.8)
                        Size: =12
                        Text: |-
                          ="🗑"
                        Width: =36
                        X: =344
