                              RadiusTopLeft: =4
                              RadiusTopRight: =4
                              Size: =9
                              Text: =If(ThisItem.IsMilestone, "⭐ Milestone", "☆ Milestone")
                              Width: =90
                              X: =110
                              Y: =56
                        - btn_tree_edit_visible_3:
                            Control: Classic/Button@2.2.0
                            Properties:
                              BorderColor: |-
                                =If(ThisItem.IsVisible,
                                    RGBA(26, 122, 74, 1),
                                    RGBA(226, 232, 240, 1))
                              BorderThickness: =1
                              Color: |-
                                =If(ThisItem.IsVisible,
                                    RGBA(26, 122, 74, 1),
                                    RGBA(148, 163, 184, 1))
                              Fill: |-
                                =If(ThisItem.IsVisible,
                                    RGBA(232, 245, 238, 1),
                                    RGBA(248, 250, 252, 1))
