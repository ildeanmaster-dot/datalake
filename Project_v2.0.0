Screens:
  Project_v2_5:
    Properties:
      Fill: =RGBA(214, 221, 224, 0.28)
      OnVisible: |-
        =Set(varProjStep_, 1);
        Set(varSelectedTaskNode, Blank());
        Set(varEditTaskNode, Blank());
        Set(varTogMilestone, false);
        Set(varTogVisible, true);
        Set(varSelectedPrecType, "");
        Set(varV4View, "tree");
        Set(varV4TaskEndDate, Blank());
        Set(varV4SubEndDate, Blank());
        Set(varV4PrecStartDate, Blank());
        Set(varV4PrecEndDate, Blank());
        Set(varEditDatesTaskId, 0);
        If(varProjectMode = "new",
            Set(reg_project, Blank());
            Concurrent(
                ClearCollect(col_proj_ordertask, Filter(Project_Tasks, ID = 0)),
                ClearCollect(colSubTasksNoProject, Filter(Project_SubTask, ID = 0)),
                ClearCollect(col_proj_precedentes, Filter(project_precedente_DEV, ID = 0)),
                ClearCollect(colProjSubTasksCatalog, Filter(Sub_task, ID = 0)),
                ClearCollect(colProjPrecTasksCatalog, Filter(Project_Tasks, ID = 0)),
                ClearCollect(colProjPrecSubTasksCatalog, Filter(Project_SubTask, ID = 0))
            );
            ClearCollect(col_proj_precflat, Filter(col_proj_ordertask, ID = 0)),
            ClearCollect(col_proj_ordertask, Filter(Project_Tasks, project_id = reg_project.ID));
            ClearCollect(colSubTasksNoProject, Filter(Project_SubTask, project_id = reg_project.ID));
            ClearCollect(col_proj_precedentes, Filter(project_precedente_DEV, project_id = reg_project.ID));
            ClearCollect(colProjSubTasksCatalog, Filter(Sub_task, ID = 0));
            ClearCollect(colProjPrecTasksCatalog, Filter(Project_Tasks, ID = 0));
            ClearCollect(colProjPrecSubTasksCatalog, Filter(Project_SubTask, ID = 0));
            ClearCollect(col_proj_precflat,
                AddColumns(col_proj_ordertask,
                    tipo, "task",
                    displayName, TaskName,
                    ordemSort, OrdemTask * 100,
                    subRef, ""));
            Collect(col_proj_precflat,
                AddColumns(colSubTasksNoProject,
                    tipo, "subtask",
                    displayName, SubTaskName,
                    ordemSort, LookUp(col_proj_ordertask, task_idf = task_idf).OrdemTask * 100 + OrdemSubTask,
                    subRef, LookUp(col_proj_ordertask, task_idf = task_idf).TaskName))
        )
    Children:
      - rect_s0_overlay_4:
          Control: Rectangle@2.3.0
          Properties:
            BorderColor: =RGBA(0, 0, 0, 0)
            Fill: =RGBA(0, 20, 50, 0.55)
            Height: =App.Height
            Visible: =varCompositionOpen
            Width: =App.ActiveScreen.Width
      - cnt_popup_34:
          Control: GroupContainer@1.5.0
          Variant: ManualLayout
          Properties:
            DropShadow: =DropShadow.Bold
            Fill: =RGBA(255, 255, 255, 1)
            Height: =712
            RadiusBottomLeft: =16
            RadiusBottomRight: =16
            RadiusTopLeft: =16
            RadiusTopRight: =16
            Visible: =varCompositionOpen
            Width: =1060
            X: =App.ActiveScreen.Width / 2 - cnt_popup_34.Width / 2
            Y: =App.ActiveScreen.Height / 2 - cnt_popup_34.Height / 2
          Children:
            - cnt_header_5:
                Control: GroupContainer@1.5.0
                Variant: ManualLayout
                Properties:
                  Fill: =RGBA(0, 45, 85, 1)
                  Height: =108
                  RadiusTopLeft: =16
                  RadiusTopRight: =16
                  Width: =cnt_popup_34.Width
                Children:
                  - lbl_header_icon_5:
                      Control: Text@0.0.51
                      Properties:
                        Align: ='TextCanvas.Align'.Center
                        FontColor: =RGBA(255, 255, 255, 1)
                        Height: =36
                        Size: =18
                        Text: ="◈"
                        VerticalAlign: =VerticalAlign.Middle
                        Width: =36
                        X: =20
                        Y: =16
                  - lbl_header_title_5:
                      Control: Text@0.0.51
                      Properties:
                        Align: ='TextCanvas.Align'.Start
                        FontColor: =RGBA(255, 255, 255, 1)
                        Height: =26
                        Size: =16
                        Text: |-
                          =If(varProjectMode = "new",
                              "New Project",
                              Coalesce(reg_project.Name, "Project"))
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =500
                        X: =64
                        Y: =16
                  - lbl_header_status_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =RGBA(0, 0, 0, 0)
                        BorderThickness: =0
                        Color: |-
                          =If(
                              reg_project.Status = "Published",
                              RGBA(128, 223, 176, 1),
                              RGBA(255, 191, 128, 1)
                          )
                        DisplayMode: =DisplayMode.View
                        Fill: |-
                          =If(
                              reg_project.Status = "Published",
                              RGBA(26, 122, 74, 0.35),
                              RGBA(199, 91, 0, 0.35)
                          )
                        Height: =22
                        RadiusBottomLeft: =20
                        RadiusBottomRight: =20
                        RadiusTopLeft: =20
                        RadiusTopRight: =20
                        Size: =11
                        Text: =Coalesce(reg_project.Status, "—")
                        Visible: =reg_project.ID > 0
                        Width: =110
                        X: =64
                        Y: =44
                  - btn_header_close_5:
                      Control: Classic/Icon@2.5.0
                      Properties:
                        BorderColor: =RGBA(255, 255, 255, 0.12)
                        Color: =RGBA(255, 255, 255, 1)
                        Height: =30
                        Icon: =Icon.CancelBadge
                        OnSelect: |-
                          =Set(varCompositionOpen, false);
                          Set(varProjectMode, "");
                          Set(varProjStep_, 1);
                          Set(varSelectedTaskNode, Blank());
                          Set(varEditTaskNode, Blank());
                          Set(varSelectedPrecType, "");
                          Set(varV4View, "tree")
                        Width: =30
                        X: =cnt_popup_34.Width - 44
                        Y: =16
                  - lbl_meta_bu_label_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(255, 255, 255, 0.45)
                        Height: =14
                        Size: =9
                        Text: ="CUSTOMER"
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =140
                        X: =20
                        Y: =72
                  - lbl_meta_bu_value_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(255, 255, 255, 1)
                        Height: =18
                        Size: =12
                        Text: =Coalesce(reg_project.Customer)
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =140
                        X: =20
                        Y: =86
                  - lbl_meta_start_label_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(255, 255, 255, 0.45)
                        Height: =14
                        Size: =9
                        Text: ="START DATE"
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =100
                        X: =175
                        Y: =72
                  - lbl_meta_start_value_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(168, 212, 240, 1)
                        Height: =18
                        Size: =11
                        Text: =Text(reg_project.StartDate, "dd/mm/yyyy")
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =100
                        X: =175
                        Y: =86
                  - lbl_meta_end_label_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(255, 255, 255, 0.45)
                        Height: =14
                        Size: =9
                        Text: ="END DATE"
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =100
                        X: =290
                        Y: =72
                  - lbl_meta_end_value_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(168, 212, 240, 1)
                        Height: =18
                        Size: =11
                        Text: =Text(reg_project.EndDate, "dd/mm/yyyy")
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =100
                        X: =290
                        Y: =86
                  - lbl_meta_duration_label_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(255, 255, 255, 0.45)
                        Height: =14
                        Size: =9
                        Text: ="DURATION"
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =120
                        X: =405
                        Y: =72
                  - lbl_meta_duration_value_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(168, 212, 240, 1)
                        Height: =18
                        Size: =11
                        Text: |-
                          =Text(DateDiff(reg_project.StartDate, reg_project.EndDate, TimeUnit.Days)) & "d (~" &
                          Text(Round(DateDiff(reg_project.StartDate, reg_project.EndDate, TimeUnit.Months), 0)) & "mo)"
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =120
                        X: =405
                        Y: =86
                  - lbl_meta_tasks_label_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(255, 255, 255, 0.45)
                        Height: =14
                        Size: =9
                        Text: ="TASKS"
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =80
                        X: =540
                        Y: =72
                  - lbl_meta_tasks_value_5:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(255, 255, 255, 1)
                        Height: =18
                        Size: =12
                        Text: =Text(CountRows(col_proj_ordertask)) & " tasks"
                        Visible: =varProjectMode = "edit"
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =80
                        X: =540
                        Y: =86
            - cnt_stepper_5:
                Control: GroupContainer@1.5.0
                Variant: ManualLayout
                Properties:
                  BorderColor: =RGBA(226, 232, 240, 1)
                  BorderThickness: =1
                  Fill: =RGBA(248, 250, 252, 1)
                  Height: =56
                  Width: =cnt_popup_34.Width
                  Y: =108
                Children:
                  - btn_step_project_6:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: |-
                          =If(varProjStep_ = 1, RGBA(0, 103, 176, 1),
                              If(varProjStep_ > 1, RGBA(26, 122, 74, 1),
                              RGBA(226, 232, 240, 1)))
                        BorderThickness: =3
                        Color: |-
                          =If(varProjStep_ = 1, RGBA(0, 103, 176, 1),
                              If(varProjStep_ > 1, RGBA(26, 122, 74, 1),
                              RGBA(100, 116, 139, 1)))
                        Fill: |-
                          =If(varProjStep_ = 1, RGBA(240, 247, 253, 1),
                              If(varProjStep_ > 1, RGBA(232, 245, 238, 1),
                              RGBA(248, 250, 252, 1)))
                        Font: =Font.'Open Sans'
                        FontWeight: =FontWeight.Bold
                        Height: =56
                        HoverBorderColor: =RGBA(0, 103, 176, 1)
                        HoverColor: =RGBA(0, 103, 176, 1)
                        HoverFill: =RGBA(240, 247, 253, 1)
                        OnSelect: =Set(varProjStep_, 1)
                        RadiusBottomLeft: =0
                        RadiusBottomRight: =0
                        RadiusTopLeft: =0
                        RadiusTopRight: =0
                        Size: =12
                        Text: =If(varProjStep_ > 1, "✅  ", "1  ") & "Project"
                        Width: =265
                  - btn_step_tasks_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: |-
                          =If(varProjStep_ = 2, RGBA(0, 103, 176, 1),
                              If(varProjStep_ > 2, RGBA(26, 122, 74, 1),
                              RGBA(226, 232, 240, 1)))
                        BorderThickness: =3
                        Color: |-
                          =If(varProjStep_ = 2, RGBA(0, 103, 176, 1),
                              If(varProjStep_ > 2, RGBA(26, 122, 74, 1),
                              RGBA(100, 116, 139, 1)))
                        DisplayMode: |-
                          =If(varProjStep_ >= 2,
                              DisplayMode.Edit,
                              DisplayMode.Disabled
                          )
                        Fill: |-
                          =If(varProjStep_ = 2, RGBA(240, 247, 253, 1),
                              If(varProjStep_ > 2, RGBA(232, 245, 238, 1),
                              RGBA(248, 250, 252, 1)))
                        Font: =Font.'Open Sans'
                        FontWeight: =FontWeight.Bold
                        Height: =56
                        HoverBorderColor: =RGBA(0, 103, 176, 1)
                        HoverColor: =RGBA(0, 103, 176, 1)
                        HoverFill: =RGBA(240, 247, 253, 1)
                        OnSelect: =Set(varProjStep_, 2)
                        RadiusBottomLeft: =0
                        RadiusBottomRight: =0
                        RadiusTopLeft: =0
                        RadiusTopRight: =0
                        Size: =12
                        Text: =If(varProjStep_ > 2, "✅  ", "2  ") & "Add Tasks"
                        Width: =265
                        X: =265
                  - btn_step_subtasks_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: |-
                          =If(varProjStep_ = 3, RGBA(0, 103, 176, 1),
                              If(varProjStep_ > 3, RGBA(26, 122, 74, 1),
                              RGBA(226, 232, 240, 1)))
                        BorderThickness: =3
                        Color: |-
                          =If(varProjStep_ = 3, RGBA(0, 103, 176, 1),
                              If(varProjStep_ > 3, RGBA(26, 122, 74, 1),
                              RGBA(100, 116, 139, 1)))
                        DisplayMode: |-
                          =If(varProjStep_ >= 3,
                              DisplayMode.Edit,
                              DisplayMode.Disabled
                          )
                        Fill: |-
                          =If(varProjStep_ = 3, RGBA(240, 247, 253, 1),
                              If(varProjStep_ > 3, RGBA(232, 245, 238, 1),
                              RGBA(248, 250, 252, 1)))
                        Font: =Font.'Open Sans'
                        FontWeight: =FontWeight.Bold
                        Height: =56
                        HoverBorderColor: =RGBA(0, 103, 176, 1)
                        HoverColor: =RGBA(0, 103, 176, 1)
                        HoverFill: =RGBA(240, 247, 253, 1)
                        OnSelect: =Set(varProjStep_, 3)
                        RadiusBottomLeft: =0
                        RadiusBottomRight: =0
                        RadiusTopLeft: =0
                        RadiusTopRight: =0
                        Size: =12
                        Text: =If(varProjStep_ > 3, "✅  ", "3  ") & "Add SubTasks"
                        Width: =265
                        X: =530
                  - btn_step_precedences_5:
                      Control: Classic/Button@2.2.0
                      Properties:
                        BorderColor: =If(varProjStep_ = 4, RGBA(0, 103, 176, 1), RGBA(226, 232, 240, 1))
                        BorderThickness: =3
                        Color: =If(varProjStep_ = 4, RGBA(0, 103, 176, 1), RGBA(100, 116, 139, 1))
                        DisplayMode: |-
                          =If(varProjStep_ >= 4,
                              DisplayMode.Edit,
                              DisplayMode.Disabled
                          )
                        Fill: =If(varProjStep_ = 4, RGBA(240, 247, 253, 1), RGBA(248, 250, 252, 1))
                        Font: =Font.'Open Sans'
                        FontWeight: =FontWeight.Bold
                        Height: =56
                        HoverBorderColor: =RGBA(0, 103, 176, 1)
                        HoverColor: =RGBA(0, 103, 176, 1)
                        HoverFill: =RGBA(240, 247, 253, 1)
                        OnSelect: =Set(varProjStep_, 4)
                        RadiusBottomLeft: =0
                        RadiusBottomRight: =0
                        RadiusTopLeft: =0
                        RadiusTopRight: =0
                        Size: =12
                        Text: ="4  Set Precedences"
                        Width: =265
                        X: =795
            - cnt_step0_body_3:
                Control: GroupContainer@1.5.0
                Variant: ManualLayout
                Properties:
                  Fill: =RGBA(255, 255, 255, 1)
                  Height: =492
                  Visible: =varProjStep_ = 1
                  Width: =cnt_popup_34.Width
                  Y: =164
                Children:
                  - lbl_s0_section_basic_3:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(0, 45, 85, 1)
                        Height: =18
                        Size: =11
                        Text: ="→  Basic Information"
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =400
                        X: =30
                        Y: =16
                  - rect_s0_divider_basic_3:
                      Control: Rectangle@2.3.0
                      Properties:
                        BorderColor: =RGBA(0, 0, 0, 0)
                        Fill: =RGBA(226, 232, 240, 1)
                        Height: =1
                        Width: =1000
                        X: =30
                        Y: =38
                  - lbl_s0_name_3:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(100, 116, 139, 1)
                        Height: =16
                        Size: =10
                        Text: ="PROJECT NAME  *"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =460
                        X: =30
                        Y: =50
                  - txt_s0_name_3:
                      Control: Classic/TextInput@2.3.2
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        Default: =If(varProjectMode = "edit", reg_project.Name, "")
                        FocusedBorderColor: =RGBA(0, 103, 176, 1)
                        FocusedBorderThickness: =2
                        Font: =Font.'Open Sans'
                        Height: =38
                        HintText: ="Enter the project name"
                        RadiusBottomLeft: =6
                        RadiusBottomRight: =6
                        RadiusTopLeft: =6
                        RadiusTopRight: =6
                        Width: =460
                        X: =30
                        Y: =68
                  - lbl_s0_logo_1:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(100, 116, 139, 1)
                        Height: =16
                        Size: =10
                        Text: ="CUSTOMER LOGO  (URL)"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =250
                        X: =780
                        Y: =50
                  - img_s0_logo_preview_1:
                      Control: Image@2.2.3
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        BorderThickness: =1
                        Fill: =RGBA(248, 250, 252, 1)
                        Height: =80
                        Image: |-
                          =If(!IsBlank(txt_s0_logo_url_1.Text),
                              txt_s0_logo_url_1.Text,
                              If(varProjectMode = "edit" && !IsBlank(reg_project.logo),
                                  reg_project.logo,
                                  Blank()
                              )
                          )
                        RadiusBottomLeft: =6
                        RadiusBottomRight: =6
                        RadiusTopLeft: =6
                        RadiusTopRight: =6
                        Width: =56
                        X: =974
                        Y: =68
                  - txt_s0_logo_url_1:
                      Control: Classic/TextInput@2.3.2
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        Default: =If(varProjectMode = "edit", Coalesce(reg_project.logo, ""), "")
                        FocusedBorderColor: =RGBA(0, 103, 176, 1)
                        FocusedBorderThickness: =2
                        Font: =Font.'Open Sans'
                        Height: =38
                        HintText: ="Paste image URL…"
                        RadiusBottomLeft: =6
                        RadiusBottomRight: =6
                        RadiusTopLeft: =6
                        RadiusTopRight: =6
                        Width: =184
                        X: =780
                        Y: =68
                  - lbl_s0_status_3:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(100, 116, 139, 1)
                        Height: =16
                        Size: =10
                        Text: ="STATUS  *"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =200
                        X: =510
                        Y: =50
                  - cbb_s0_status_3:
                      Control: Classic/ComboBox@2.4.0
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        DefaultSelectedItems: |-
                          =If(varProjectMode = "edit",
                              {Value: reg_project.Status},
                              {Value: "Active"})
                        DisplayFields: =["Value"]
                        FocusedBorderColor: =RGBA(0, 103, 176, 1)
                        FocusedBorderThickness: =2
                        Font: =Font.'Open Sans'
                        Height: =38
                        InputTextPlaceholder: ="Select status…"
                        Items: =["Active", "On Hold", "Cancelled", "Published"]
                        SearchFields: =["Value"]
                        SelectMultiple: =false
                        Width: =200
                        X: =510
                        Y: =68
                  - lbl_s0_bu_3:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(100, 116, 139, 1)
                        Height: =16
                        Size: =10
                        Text: ="BUSINESS UNIT  *"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =300
                        X: =730
                        Y: =50
                  - cbb_s0_bu_3:
                      Control: Classic/ComboBox@2.4.0
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        DisplayFields: =["Name"]
                        FocusedBorderColor: =RGBA(0, 103, 176, 1)
                        FocusedBorderThickness: =2
                        Font: =Font.'Open Sans'
                        Height: =38
                        InputTextPlaceholder: ="Select BU…"
                        Items: =BusinessUnit
                        SearchFields: =["Name"]
                        SelectMultiple: =false
                        Width: =300
                        X: =730
                        Y: =68
                  - lbl_s0_type_3:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(100, 116, 139, 1)
                        Height: =16
                        Size: =10
                        Text: ="PROJECT TYPE  *"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =220
                        X: =30
                        Y: =122
                  - cbb_s0_type_3:
                      Control: Classic/ComboBox@2.4.0
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        DefaultSelectedItems: |-
                          =If(varProjectMode = "edit",
                              {Value: reg_project.Project_Type},
                              Blank())
                        DisplayFields: =["Value"]
                        FocusedBorderColor: =RGBA(0, 103, 176, 1)
                        FocusedBorderThickness: =2
                        Font: =Font.'Open Sans'
                        Height: =38
                        InputTextPlaceholder: ="Select type…"
                        Items: =["Remarketing", "New Aircraft"]
                        SearchFields: =["Value"]
                        SelectMultiple: =false
                        Width: =220
                        X: =30
                        Y: =140
                  - lbl_s0_template_3:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(100, 116, 139, 1)
                        Height: =16
                        Size: =10
                        Text: ="TEMPLATE  *"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =440
                        X: =270
                        Y: =122
                  - cbb_s0_template_3:
                      Control: Classic/ComboBox@2.4.0
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        DisplayFields: =["Name"]
                        FocusedBorderColor: =RGBA(0, 103, 176, 1)
                        FocusedBorderThickness: =2
                        Font: =Font.'Open Sans'
                        Height: =38
                        InputTextPlaceholder: ="Select template…"
                        Items: =Filter(Templates, Status.Value = "Published")
                        SearchFields: =["Name"]
                        SelectMultiple: =false
                        Width: =440
                        X: =270
                        Y: =140
                  - lbl_s0_aircraft_3:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(100, 116, 139, 1)
                        Height: =16
                        Size: =10
                        Text: ="AIRCRAFT  *"
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =300
                        X: =730
                        Y: =122
                  - cbb_s0_aircraft_3:
                      Control: Classic/ComboBox@2.4.0
                      Properties:
                        BorderColor: =RGBA(203, 213, 225, 1)
                        DisplayFields: =["Aircraft"]
                        FocusedBorderColor: =RGBA(0, 103, 176, 1)
                        FocusedBorderThickness: =2
                        Font: =Font.'Open Sans'
                        Height: =38
                        InputTextPlaceholder: ="Select aircraft…"
                        Items: =Filter(Aircraft, IsActive = "Active")
                        SearchFields: =["Aircraft"]
                        SelectMultiple: =false
                        Width: =300
                        X: =730
                        Y: =140
                  - lbl_s0_section_timeline_3:
                      Control: Text@0.0.51
                      Properties:
                        FontColor: =RGBA(0, 45, 85, 1)
                        Height: =18
                        Size: =11
                        Text: ="→  Timeline"
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Bold
                        Width: =400
                        X: =30
                        Y: =196
                  - rect_s0_divider_timeline_3:
                      Control: Rectangle@2.3.0
                      Properties:
                        BorderColor: =RGBA(0, 0, 0, 0)
                        Fill: =RGBA(226, 232, 240, 1)
                        Height: =1
                        Width: =1000
                        X: =30
                        Y: =218
