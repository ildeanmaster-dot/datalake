                                            template_idf: vNewTemplate.ID,
                                            task_idf: task_idf,
                                            OrdemSubTask: OrdemSubTask,
                                            Status: Status
                                        })
                                    );
                                    ForAll(
                                        colDupPrecs,
                                        Patch(Template_Precedente_DEV, Defaults(Template_Precedente_DEV), {
                                            template_idf: vNewTemplate.ID,
                                            task_idf: task_idf,
                                            subtask_idf: subtask_idf,
