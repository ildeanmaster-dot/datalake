                                            preceding_task_idf: preceding_task_idf,
                                            preceding_subtask_idf: preceding_subtask_idf,
                                            StartDate: StartDate,
                                            EndDate: EndDate
                                        })
                                    );
                                    Set(varDuplicateDialogOpen, false);
                                    Notify("✅ Template duplicated successfully! Open it from the template list.", NotificationType.Success, 4000)
                                )
                            )
                        )
