                                        colDupTasks,
                                        Patch(Template_Task, Defaults(Template_Task), {
                                            TemplateName: vNewTemplate.Name,
                                            functional_area: functional_area,
                                            functional_area_id: functional_area_id,
                                            template_idf: vNewTemplate.ID,
                                            TaskName: TaskName,
                                            task_idf: task_idf,
