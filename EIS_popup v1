                        DisplayMode.Disabled,
                        DisplayMode.Edit
                    )
                  Fill: =RGBA(199, 91, 0, 1)
                  Font: =Font.'Open Sans'
                  FontWeight: =FontWeight.Bold
                  Height: =36
                  HoverFill: =RGBA(168, 75, 0, 1)
                  OnSelect: |-
                    =If(
                        reg_template.Status.Value <> "Published" || reg_template.ID = 0,
                        Notify("⚠️ Only Published templates can be duplicated.", NotificationType.Warning, 3500),
